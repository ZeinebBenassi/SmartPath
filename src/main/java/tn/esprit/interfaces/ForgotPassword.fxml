<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.controllers.ForgotPasswordController"
           prefWidth="920" prefHeight="600"
           style="-fx-background-color: linear-gradient(to bottom right, #eef3ff, #f0f7ff);">

    <HBox alignment="CENTER" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 20;
                 -fx-border-color: #dce8fa; -fx-border-radius: 20; -fx-border-width: 1;"
          prefWidth="840" prefHeight="520">

        <!-- ── Panneau gauche ── -->
        <VBox alignment="CENTER" spacing="18" prefWidth="310"
              style="-fx-background-color: linear-gradient(to bottom right, #1e3a8a, #2563eb);
                     -fx-background-radius: 20 0 0 20; -fx-padding: 44;">

            <VBox alignment="CENTER" spacing="8">
                <Label text="🔑"
                       style="-fx-font-size: 36; -fx-padding: 0 0 4 0;"/>
                <Label text="SmartPath"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Réinitialisation"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85);"/>
            </VBox>

            <Label wrapText="true" maxWidth="230" textAlignment="CENTER"
                   text="Suivez les étapes pour récupérer l'accès à votre compte en toute sécurité."
                   style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.75); -fx-text-alignment: center;"/>

            <HBox alignment="CENTER" spacing="6">
                <Circle radius="4" fill="white" opacity="0.4"/>
                <Circle radius="4" fill="white" opacity="0.9"/>
                <Circle radius="4" fill="white" opacity="0.4"/>
            </HBox>
        </VBox>

        <!-- ── Panneau droit ── -->
        <VBox alignment="CENTER" spacing="16" prefWidth="530"
              style="-fx-padding: 44 52;">

            <VBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Réinitialiser votre accès"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <Label text="Entrez votre email pour recevoir un code de réinitialisation."
                       style="-fx-font-size: 12; -fx-text-fill: #8898b8;"/>
            </VBox>

            <!-- Étape 1 : Email -->
            <VBox spacing="5" maxWidth="390">
                <Label text="Adresse email"
                       style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"/>
                <TextField fx:id="emailField" promptText="votre@email.com" prefHeight="44"
                           style="-fx-background-color: #f7f9fc; -fx-text-fill: #1a2340;
                                  -fx-prompt-text-fill: #a0aec0; -fx-border-color: #e2e8f4;
                                  -fx-border-radius: 9; -fx-background-radius: 9;
                                  -fx-padding: 10 14; -fx-font-size: 13;"/>
            </VBox>

            <Button fx:id="sendCodeBtn" text="Envoyer le code de vérification"
                    onAction="#handleSendCode" prefWidth="390" prefHeight="44"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white;
                           -fx-font-size: 13; -fx-font-weight: bold;
                           -fx-background-radius: 9; -fx-cursor: hand;"/>

            <!-- Étape 2 : Code + nouveau mot de passe -->
            <VBox fx:id="step2Box" spacing="10" maxWidth="390">
                <Label text="Code reçu par email"
                       style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"/>
                <TextField fx:id="tokenField" promptText="Entrez le code" prefHeight="44"
                           style="-fx-background-color: #f7f9fc; -fx-text-fill: #1a2340;
                                  -fx-prompt-text-fill: #a0aec0; -fx-border-color: #e2e8f4;
                                  -fx-border-radius: 9; -fx-background-radius: 9;
                                  -fx-padding: 10 14; -fx-font-size: 13;"/>

                <Label text="Nouveau mot de passe"
                       style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"/>
                <PasswordField fx:id="newPasswordField" promptText="Nouveau mot de passe" prefHeight="44"
                               style="-fx-background-color: #f7f9fc; -fx-text-fill: #1a2340;
                                      -fx-prompt-text-fill: #a0aec0; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 9; -fx-background-radius: 9;
                                      -fx-padding: 10 14; -fx-font-size: 13;"/>

                <Label text="Confirmer le mot de passe"
                       style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Confirmer" prefHeight="44"
                               style="-fx-background-color: #f7f9fc; -fx-text-fill: #1a2340;
                                      -fx-prompt-text-fill: #a0aec0; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 9; -fx-background-radius: 9;
                                      -fx-padding: 10 14; -fx-font-size: 13;"/>

                <Button fx:id="resetBtn" text="Réinitialiser le mot de passe"
                        onAction="#handleReset" prefWidth="390" prefHeight="44"
                        style="-fx-background-color: #10b981; -fx-text-fill: white;
                               -fx-font-size: 13; -fx-font-weight: bold;
                               -fx-background-radius: 9; -fx-cursor: hand;"/>
            </VBox>

            <!-- Message retour -->
            <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="390"
                   style="-fx-font-size: 12;"/>

            <Button text="← Retour à la connexion" onAction="#goToLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a;
                           -fx-font-size: 12; -fx-cursor: hand; -fx-underline: true;"/>
        </VBox>
    </HBox>
</StackPane>
