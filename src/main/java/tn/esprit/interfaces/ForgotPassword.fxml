<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.controllers.ForgotPasswordController"
           prefWidth="900" prefHeight="600"
           style="-fx-background-color: linear-gradient(to bottom right, #f4f6fb, #eaf0fb);">

    <HBox alignment="CENTER" spacing="0" style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #e2e8f4; -fx-border-radius: 18; -fx-border-width: 1;" prefWidth="840" prefHeight="520">

        <VBox alignment="CENTER" spacing="14" prefWidth="320"
              style="-fx-background-color: linear-gradient(to bottom right, #1e3a8a, #2563eb); -fx-background-radius: 18 0 0 18; -fx-padding: 34;">
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 6 0;">
                <Label text="🛣" style="-fx-font-size: 26;"/>
                <Label text="🎓" style="-fx-font-size: 18;"/>
            </HBox>
            <Label text="SmartPath" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="IT" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.88);"/>
            <Label text="Récupération" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Mot de passe oublié" style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.82);"/>
            <Label text="Suivez les étapes pour réinitialiser votre accès" wrapText="true" maxWidth="230" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.80); -fx-text-alignment: center;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="14" prefWidth="520" style="-fx-padding: 36 44;">
            <Label text="Mot de passe oublié" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>

            <VBox spacing="6" maxWidth="380">
                <Label text="Adresse email" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"/>
                <TextField fx:id="emailField" promptText="votre@email.com" prefHeight="42"
                           style="-fx-background-color: #f4f6fb; -fx-text-fill: #1a2340; -fx-prompt-text-fill: #8898b8; -fx-border-color: #e2e8f4; -fx-border-radius: 8; -fx-background-radius: 8;"/>
            </VBox>

            <Button fx:id="sendCodeBtn" text="Envoyer le code" onAction="#handleSendCode" prefWidth="380" prefHeight="42"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8;"/>

            <VBox fx:id="step2Box" spacing="10" maxWidth="380">
                <TextField fx:id="tokenField" promptText="Code de vérification" prefHeight="42"
                           style="-fx-background-color: #f4f6fb; -fx-text-fill: #1a2340; -fx-prompt-text-fill: #8898b8; -fx-border-color: #e2e8f4; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <PasswordField fx:id="newPasswordField" promptText="Nouveau mot de passe" prefHeight="42"
                               style="-fx-background-color: #f4f6fb; -fx-text-fill: #1a2340; -fx-prompt-text-fill: #8898b8; -fx-border-color: #e2e8f4; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Confirmation" prefHeight="42"
                               style="-fx-background-color: #f4f6fb; -fx-text-fill: #1a2340; -fx-prompt-text-fill: #8898b8; -fx-border-color: #e2e8f4; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <Button fx:id="resetBtn" text="Réinitialiser" onAction="#handleReset" prefWidth="380" prefHeight="42"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            </VBox>

            <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="380" style="-fx-font-size: 12;"/>
            <Button text="← Retour à la connexion" onAction="#goToLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 12; -fx-underline: true;"/>
        </VBox>
    </HBox>
</StackPane>

