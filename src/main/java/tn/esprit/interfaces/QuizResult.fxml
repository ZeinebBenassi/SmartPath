<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.QuizResultController"
            prefWidth="860" prefHeight="700"
            style="-fx-background-color: #F4F7FB;">

    <top>
        <HBox style="-fx-background-color: #FFFFFF; -fx-padding: 16 28;
                     -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;"
              alignment="CENTER_LEFT">
            <Label text="SmartPath" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6366F1;"/>
            <Label text="  —  Résultats du Quiz" style="-fx-font-size: 16px; -fx-text-fill: #94A3B8;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #F4F7FB; -fx-background: #F4F7FB; -fx-border-width: 0;">
            <VBox spacing="20" style="-fx-padding: 28 50;">

                <!-- PROFIL -->
                <VBox spacing="12" alignment="CENTER"
                      style="-fx-background-color: linear-gradient(to bottom right,#6366F1,#8B5CF6);
                             -fx-background-radius: 16; -fx-padding: 36 40;
                             -fx-effect: dropshadow(gaussian,rgba(99,102,241,0.4),20,0,0,6);">
                    <Label fx:id="lblCongrats" text="🎉  Félicitations ! Voici votre profil"
                           style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: bold;"/>
                    <Label fx:id="lblProfileEmoji" text="🎓" style="-fx-font-size: 56px;"/>
                    <Label fx:id="lblProfileType" text="Chargement..."
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="lblProfileDesc" text="" wrapText="true" maxWidth="500"
                           style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.85); -fx-text-alignment: center;"/>
                </VBox>

                <!-- SCORES -->
                <VBox spacing="16"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 16;
                             -fx-border-color: #E2E8F0; -fx-border-radius: 16; -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.05),10,0,0,2); -fx-padding: 28 30;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📊" style="-fx-font-size: 18px;"/>
                        <Label text="Analyse Détaillée de Votre Profil"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #F1F5F9;"/>
                    <VBox fx:id="vboxScores" spacing="8"/>
                </VBox>

                <!-- BOUTONS -->
                <HBox spacing="14" alignment="CENTER" style="-fx-padding: 10 0 20 0;">
                    <Button fx:id="btnRetake" text="🔄  Refaire le Quiz" onAction="#handleRetake"
                            style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-font-size: 13px; -fx-background-radius: 20; -fx-padding: 9 20; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian,rgba(99,102,241,0.35),8,0,0,3);"/>
                    <Button fx:id="btnClose" text="🏠  Retour Dashboard" onAction="#handleClose"
                            style="-fx-background-color: #F8FAFC; -fx-text-fill: #64748B; -fx-background-radius: 20;
                                   -fx-padding: 9 20; -fx-cursor: hand; -fx-border-color: #E2E8F0;
                                   -fx-border-radius: 20; -fx-border-width: 1;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
