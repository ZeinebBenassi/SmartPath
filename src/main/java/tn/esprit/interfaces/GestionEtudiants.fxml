<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.GestionEtudiantsController"
      spacing="0"
      style="-fx-background-color: #f4f7fb;">

    <!-- Barre contrôles -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white; -fx-padding: 14 20;
                 -fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 0 0 1 0;">

        <Button text="← Retour" onAction="#goBack"
                style="-fx-background-color: #f4f6fb; -fx-text-fill: #5a6a8a;
                       -fx-font-size: 12; -fx-padding: 7 14; -fx-background-radius: 8;
                       -fx-border-color: #e2e8f4; -fx-border-radius: 8; -fx-cursor: hand;"/>

        <!-- Recherche -->
        <HBox alignment="CENTER_LEFT" spacing="0" prefWidth="200"
              style="-fx-background-color: #f8fafc; -fx-background-radius: 8;
                     -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 7 12;">
            <Label text="🔍 " style="-fx-text-fill: #cbd5e1; -fx-font-size: 13;"/>
            <TextField fx:id="searchField" promptText="Rechercher étudiant..."
                       style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 13;"
                       prefWidth="160"/>
        </HBox>

        <Pane HBox.hgrow="ALWAYS"/>

        <Label fx:id="countLabel" text="0 étudiant(s)"
               style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>

        <Button fx:id="btnAjouter" text="+ Ajouter étudiant" onAction="#handleAjouter"
                style="-fx-background-color: #2563eb; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 13;
                       -fx-background-radius: 8; -fx-padding: 9 22; -fx-cursor: hand;"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: #f4f7fb; -fx-padding: 16 20;">
        <TableView fx:id="etudiantsTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-background-radius: 12;
                          -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-border-width: 1;">
            <columns>
                <TableColumn fx:id="colNom"       text="Nom"        prefWidth="120"/>
                <TableColumn fx:id="colPrenom"     text="Prénom"     prefWidth="120"/>
                <TableColumn fx:id="colEmail"      text="Email"      prefWidth="200"/>
                <TableColumn fx:id="colNiveau"     text="Niveau"     prefWidth="80"/>
                <TableColumn fx:id="colCIN"        text="CIN"        prefWidth="100"/>
                <TableColumn fx:id="colTelephone"  text="Téléphone"  prefWidth="110"/>
                <TableColumn fx:id="colStatus"     text="Statut"     prefWidth="80"/>
                <TableColumn fx:id="colActions"    text="Actions"    prefWidth="160"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
