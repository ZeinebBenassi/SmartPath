<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    GestionFilieres.fxml - Page enfant (chargée dans contentArea Admin)
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.GestionFilieresController"
      spacing="16"
      style="-fx-background-color: #f4f6fb; -fx-padding: 0;">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Gestion des filières"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouvelle filière"
                onAction="#addFiliere"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 8 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <TableView fx:id="filieresTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-border-color: #e2e8f4; -fx-border-radius: 12; -fx-background-radius: 12; -fx-background-insets: 0;">
        <columns>
            <TableColumn fx:id="colId"          text="ID"          prefWidth="60"/>
            <TableColumn fx:id="colNom"         text="Nom"         prefWidth="200"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="350"/>
            <TableColumn fx:id="colActions"     text="Actions"     prefWidth="160"/>
        </columns>
    </TableView>

</VBox>
