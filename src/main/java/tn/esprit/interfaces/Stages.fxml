<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Stages.fxml - Page enfant (chargée dans le contentArea du dashboard)
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.StagesController"
      spacing="16"
      style="-fx-background-color: #f4f6fb; -fx-padding: 0;">

    <!-- Barre d'outils -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Stages &amp; Offres"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Rechercher..." onAction="#handleSearch" prefWidth="220"
                   style="-fx-background-color: white; -fx-border-color: #dce5f6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 14;"/>
        <ComboBox fx:id="typeFilter" onAction="#handleFilter" prefWidth="160"
                  style="-fx-background-color: white; -fx-border-color: #dce5f6; -fx-border-radius: 8; -fx-background-radius: 8;"/>
    </HBox>

    <!-- Contenu principal -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <!-- Liste -->
        <VBox prefWidth="360" spacing="10"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 14;">
            <Label text="Offres disponibles"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
            <ListView fx:id="offresList" VBox.vgrow="ALWAYS"/>
        </VBox>

        <!-- Détail -->
        <VBox spacing="14" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 18;">
            <Label fx:id="offreTitre" text="Sélectionnez une offre"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
            <HBox spacing="12">
                <Label fx:id="offreEntreprise" text="" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                <Label fx:id="offreDuree"      text="" style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                <Label fx:id="offreType"       text="" style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
            </HBox>

            <VBox spacing="6">
                <Label text="Description" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <Label fx:id="offreDescription" wrapText="true"
                       style="-fx-font-size: 12; -fx-text-fill: #475569; -fx-background-color: #f8fbff; -fx-background-radius: 12; -fx-border-color: #e3ecfa; -fx-border-radius: 12; -fx-padding: 12;"/>
            </VBox>

            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <Label text="Compétences demandées" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <Label fx:id="offreCompetences" wrapText="true"
                       style="-fx-font-size: 12; -fx-text-fill: #475569; -fx-background-color: #f8fbff; -fx-background-radius: 12; -fx-border-color: #e3ecfa; -fx-border-radius: 12; -fx-padding: 12;"
                       VBox.vgrow="ALWAYS"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnPostuler" text="Postuler" onAction="#postuler"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </HBox>

</VBox>
