<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.GestionUsersController"
      stylesheets="@smartpath.css"
      spacing="15"
      styleClass="app-bg">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Barre de controle -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="section-card-accent">
        
        <!-- Barre de recherche -->
        <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="250"/>
        
        <!-- Filtre par role -->
        <ComboBox fx:id="roleFilter" promptText="Tous les rôles" prefWidth="150"/>
        
        <!-- Espace flexible -->
        <Pane HBox.hgrow="ALWAYS"/>
        
        <!-- Compteur -->
        <Label fx:id="countLabel" text="0 utilisateurs" styleClass="card-subtitle"/>
        
        <!-- Bouton Ajouter -->
        <Button fx:id="btnAjouter" text="Ajouter" onAction="#handleAjouter" styleClass="btn-secondary">
            <HBox.margin>
                <Insets left="10" />
            </HBox.margin>
        </Button>
    </HBox>

    <!-- Table principale -->
    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="table-accent">
        <columns>
            <TableColumn fx:id="colNom"      text="Nom"         prefWidth="120" sortable="true"/>
            <TableColumn fx:id="colPrenom"   text="Prenom"      prefWidth="120" sortable="true"/>
            <TableColumn fx:id="colEmail"    text="Email"       prefWidth="200" sortable="true"/>
            <TableColumn fx:id="colRole"     text="Role"        prefWidth="100" sortable="true"/>
            <TableColumn fx:id="colStatus"   text="Statut"      minWidth="80" prefWidth="90" sortable="true"/>
            <TableColumn fx:id="colDate"     text="Inscription" prefWidth="120" sortable="true"/>
            <TableColumn fx:id="colActions"  text="Actions"     prefWidth="140" sortable="false"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>

</VBox>

