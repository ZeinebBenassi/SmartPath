<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.GestionUsersController"
      spacing="0"
      style="-fx-background-color: #f4f7fb;">

    <!-- Barre de controles -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white;
                 -fx-padding: 14 20;
                 -fx-border-color: transparent transparent #e2e8f0 transparent;
                 -fx-border-width: 0 0 1 0;">

        <!-- Champ recherche -->
        <HBox alignment="CENTER_LEFT" spacing="0" prefWidth="200"
              style="-fx-background-color: #f8fafc;
                     -fx-background-radius: 8;
                     -fx-border-color: #e2e8f0;
                     -fx-border-radius: 8;
                     -fx-border-width: 1;
                     -fx-padding: 7 12;">
            <Label text="🔍 " style="-fx-text-fill: #cbd5e1; -fx-font-size: 13;"/>
            <TextField fx:id="searchField" promptText="Rechercher..."
                       style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 13;"
                       prefWidth="150"/>
        </HBox>

        <!-- Filtre role -->
        <ComboBox fx:id="roleFilter" promptText="Tous" prefWidth="140"
                  style="-fx-background-color: white;
                         -fx-border-color: #e2e8f0;
                         -fx-border-radius: 8;
                         -fx-background-radius: 8;
                         -fx-font-size: 13;"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Compteur -->
        <Label fx:id="countLabel" text="0 utilisateurs"
               style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>

        <!-- Bouton Ajouter -->
        <Button fx:id="btnAjouter" text="Ajouter" onAction="#handleAjouter"
                style="-fx-background-color: #2563eb;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 13;
                       -fx-background-radius: 8;
                       -fx-padding: 9 22;
                       -fx-cursor: hand;"/>
    </HBox>

    <!-- Zone table avec fond gris -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: #f4f7fb; -fx-padding: 16 20;">

        <!-- Table -->
        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 12;
                          -fx-border-color: #e2e8f0;
                          -fx-border-radius: 12;
                          -fx-border-width: 1;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
            <columns>
                <TableColumn fx:id="colNom"     text="Nom"         prefWidth="130" sortable="true"
                             style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #374151;"/>
                <TableColumn fx:id="colPrenom"  text="Prenom"      prefWidth="130" sortable="true"
                             style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #374151;"/>
                <TableColumn fx:id="colEmail"   text="Email"       prefWidth="210" sortable="true"
                             style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #374151;"/>
                <TableColumn fx:id="colRole"    text="Role"        prefWidth="100" sortable="true"
                             style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #374151;"/>
                <TableColumn fx:id="colStatus"  text="Statut"      prefWidth="80"  sortable="true"
                             style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #374151;"/>
                <TableColumn fx:id="colDate"    text="Inscription" prefWidth="120" sortable="true"
                             style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #374151;"/>
                <TableColumn fx:id="colActions" text="Actions"     prefWidth="130" sortable="false"
                             style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #374151;"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>
    </VBox>

</VBox>
