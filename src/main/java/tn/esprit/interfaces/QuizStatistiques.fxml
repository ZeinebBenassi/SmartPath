<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    QuizStatistiques.fxml — IDENTIQUE à admin/quiz/statistics.html.twig Symfony
    Charts JavaFX Canvas :
      - Bar Chart  vertical  (filières)  → vboxBarChart
      - Donut Chart          (profils)   → vboxDonutChart  (roue cutout 62%)
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.QuizStatisticsController"
      spacing="0"
      style="-fx-background-color:#f8fafc;">

    <!-- ══ EN-TÊTE ══ -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:white; -fx-padding:18 28;
                 -fx-border-color:transparent transparent #e2e8f0 transparent;
                 -fx-border-width:0 0 1 0;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),4,0,0,1);">
        <VBox spacing="3">
            <Label text="📊  Statistiques du Quiz"
                   style="-fx-font-size:20px; -fx-font-weight:900; -fx-text-fill:#1e293b;"/>
            <Label text="Analyse des résultats · profils types · recommandations de filières"
                   style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:#f8fafc; -fx-background:#f8fafc; -fx-border-width:0;">
        <VBox spacing="18" style="-fx-padding:22 28 28 28;">

            <!-- ══ BANNER TOTAL ══ -->
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-background-color:linear-gradient(to right,#6366f1,#0ea5e9);
                         -fx-background-radius:24px; -fx-padding:24 32;
                         -fx-effect:dropshadow(gaussian,rgba(99,102,241,0.35),20,0,0,6);">
                <Label text="🎯" style="-fx-font-size:42px;"/>
                <VBox spacing="4">
                    <Label fx:id="lblBannerTotal" text="0"
                           style="-fx-font-size:52px; -fx-font-weight:900; -fx-text-fill:white;"/>
                    <Label text="Quiz passés au total"
                           style="-fx-font-size:14px; -fx-text-fill:#ddd6fe;"/>
                    <Label fx:id="lblBannerMiniStats" text="0 filières · 0 profils distincts"
                           style="-fx-font-size:11px; -fx-text-fill:#c7d2fe;"/>
                </VBox>
                <Pane HBox.hgrow="ALWAYS"/>
                <VBox spacing="6" alignment="CENTER"
                      style="-fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:16; -fx-padding:14 22;">
                    <Label fx:id="lblInsightFilieres" text="—"
                           style="-fx-font-size:24px; -fx-font-weight:900; -fx-text-fill:white;"/>
                    <Label text="Filières analysées"
                           style="-fx-font-size:10px; -fx-text-fill:#ddd6fe;"/>
                </VBox>
                <VBox spacing="6" alignment="CENTER"
                      style="-fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:16; -fx-padding:14 22;">
                    <Label fx:id="lblInsightProfils" text="—"
                           style="-fx-font-size:24px; -fx-font-weight:900; -fx-text-fill:white;"/>
                    <Label text="Profils types"
                           style="-fx-font-size:10px; -fx-text-fill:#ddd6fe;"/>
                </VBox>
            </HBox>

            <!-- ══ ÉTAT VIDE ══ -->
            <VBox fx:id="vboxEmpty" alignment="CENTER" spacing="14"
                  managed="false" visible="false"
                  style="-fx-background-color:white; -fx-background-radius:18;
                         -fx-border-color:#e2e8f0; -fx-border-radius:18; -fx-border-width:1;
                         -fx-padding:60;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                <Label text="📊" style="-fx-font-size:52px;"/>
                <Label text="Aucune statistique disponible"
                       style="-fx-font-size:16px; -fx-font-weight:700; -fx-text-fill:#475569;"/>
                <Label text="Les statistiques apparaîtront après le premier passage de quiz."
                       style="-fx-font-size:12px; -fx-text-fill:#94a3b8;"/>
            </VBox>

            <!-- ══ CONTENU PRINCIPAL ══ -->
            <VBox fx:id="vboxContent" spacing="18">

                <!-- ─ 4 Insight cards (.qa-insights Symfony) ─ -->
                <HBox spacing="14">
                    <!-- Filière #1 -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white; -fx-background-radius:16;
                                 -fx-border-color:#e2e8f0; -fx-border-radius:16; -fx-border-width:1;
                                 -fx-padding:16 20;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,2);">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="🏆" style="-fx-font-size:30px;"/>
                            <VBox spacing="3">
                                <Label text="FILIÈRE #1"
                                       style="-fx-font-size:10px; -fx-text-fill:#64748b; -fx-font-weight:700;"/>
                                <Label fx:id="lblTopFiliereName" text="—"
                                       style="-fx-font-size:13px; -fx-font-weight:900; -fx-text-fill:#1e293b; -fx-wrap-text:true;"/>
                                <Label fx:id="lblTopFiliereCount" text="0 recommandation"
                                       style="-fx-font-size:10px; -fx-text-fill:#94a3b8;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <!-- Profil dominant -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white; -fx-background-radius:16;
                                 -fx-border-color:#e2e8f0; -fx-border-radius:16; -fx-border-width:1;
                                 -fx-padding:16 20;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,2);">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="👑" style="-fx-font-size:30px;"/>
                            <VBox spacing="3">
                                <Label text="PROFIL DOMINANT"
                                       style="-fx-font-size:10px; -fx-text-fill:#64748b; -fx-font-weight:700;"/>
                                <Label fx:id="lblTopProfilName" text="—"
                                       style="-fx-font-size:13px; -fx-font-weight:900; -fx-text-fill:#1e293b; -fx-wrap-text:true;"/>
                                <Label fx:id="lblTopProfilCount" text="0 étudiant"
                                       style="-fx-font-size:10px; -fx-text-fill:#94a3b8;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <!-- Filières analysées -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white; -fx-background-radius:16;
                                 -fx-border-color:#e2e8f0; -fx-border-radius:16; -fx-border-width:1;
                                 -fx-padding:16 20;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,2);">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="📊" style="-fx-font-size:30px;"/>
                            <VBox spacing="3">
                                <Label text="FILIÈRES ANALYSÉES"
                                       style="-fx-font-size:10px; -fx-text-fill:#64748b; -fx-font-weight:700;"/>
                                <Label fx:id="lblInsightFilieres2" text="—"
                                       style="-fx-font-size:24px; -fx-font-weight:900; -fx-text-fill:#6366f1;"/>
                                <Label text="filières recommandées"
                                       style="-fx-font-size:10px; -fx-text-fill:#94a3b8;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <!-- Profils distincts -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white; -fx-background-radius:16;
                                 -fx-border-color:#e2e8f0; -fx-border-radius:16; -fx-border-width:1;
                                 -fx-padding:16 20;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,2);">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="🎓" style="-fx-font-size:30px;"/>
                            <VBox spacing="3">
                                <Label text="PROFILS DISTINCTS"
                                       style="-fx-font-size:10px; -fx-text-fill:#64748b; -fx-font-weight:700;"/>
                                <Label fx:id="lblInsightProfils2" text="—"
                                       style="-fx-font-size:24px; -fx-font-weight:900; -fx-text-fill:#10b981;"/>
                                <Label fx:id="lblInsightProfilsSub" text="sur 0 quiz"
                                       style="-fx-font-size:10px; -fx-text-fill:#94a3b8;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ─ Section 1 : Listes (3fr + 2fr — .qa-grid-2 Symfony) ─ -->
                <HBox spacing="14" alignment="TOP_LEFT">
                    <!-- Recommandations par filière -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white; -fx-background-radius:18;
                                 -fx-border-color:#e2e8f0; -fx-border-radius:18; -fx-border-width:1;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding:14 20; -fx-background-color:#f8fafc;
                                     -fx-background-radius:18 18 0 0;
                                     -fx-border-color:transparent transparent #e2e8f0 transparent;
                                     -fx-border-width:0 0 1 0;">
                            <Label text="🏆  Recommandations par Filière"
                                   style="-fx-font-weight:700; -fx-text-fill:#1e293b; -fx-font-size:13px;"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblBadgeFilieres" text="0 filières"
                                   style="-fx-background-color:#ddd6fe; -fx-text-fill:#6366f1;
                                          -fx-background-radius:50px; -fx-padding:3 12;
                                          -fx-font-size:11px; -fx-font-weight:700;"/>
                        </HBox>
                        <VBox fx:id="vboxFilieres" spacing="0"
                              style="-fx-padding:10 20 16 20;"/>
                    </VBox>
                    <!-- Profils types -->
                    <VBox prefWidth="310"
                          style="-fx-background-color:white; -fx-background-radius:18;
                                 -fx-border-color:#e2e8f0; -fx-border-radius:18; -fx-border-width:1;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding:14 20; -fx-background-color:#f8fafc;
                                     -fx-background-radius:18 18 0 0;
                                     -fx-border-color:transparent transparent #e2e8f0 transparent;
                                     -fx-border-width:0 0 1 0;">
                            <Label text="👤  Profils Types"
                                   style="-fx-font-weight:700; -fx-text-fill:#1e293b; -fx-font-size:13px;"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblBadgeProfils" text="0 profils"
                                   style="-fx-background-color:#d1fae5; -fx-text-fill:#065f46;
                                          -fx-background-radius:50px; -fx-padding:3 12;
                                          -fx-font-size:11px; -fx-font-weight:700;"/>
                        </HBox>
                        <VBox fx:id="vboxProfils" spacing="0"
                              style="-fx-padding:10 20 16 20;"/>
                    </VBox>
                </HBox>

                <!-- ─ Section 2 : Charts (.qa-grid-2-eq Symfony — 1fr 1fr) ─ -->
                <HBox spacing="14" alignment="TOP_LEFT">

                    <!-- Bar Chart filières — chart-container-lg height:320px -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white; -fx-background-radius:18;
                                 -fx-border-color:#e2e8f0; -fx-border-radius:18; -fx-border-width:1;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding:14 20; -fx-background-color:#f8fafc;
                                     -fx-background-radius:18 18 0 0;
                                     -fx-border-color:transparent transparent #e2e8f0 transparent;
                                     -fx-border-width:0 0 1 0;">
                            <Label text="📊  Diagramme — Filières recommandées"
                                   style="-fx-font-weight:700; -fx-text-fill:#1e293b; -fx-font-size:13px;"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Label text="Bar Chart"
                                   style="-fx-background-color:#ddd6fe; -fx-text-fill:#6366f1;
                                          -fx-background-radius:50px; -fx-padding:3 12;
                                          -fx-font-size:11px; -fx-font-weight:700;"/>
                        </HBox>
                        <!-- chart-container-lg height:320px →  prefHeight:320 -->
                        <ScrollPane fitToWidth="true" prefHeight="320"
                                    style="-fx-background-color:transparent; -fx-border-width:0;">
                            <VBox fx:id="vboxBarChart" spacing="0" alignment="CENTER_LEFT"
                                  style="-fx-padding:16 16 12 16;"/>
                        </ScrollPane>
                    </VBox>

                    <!-- Donut Chart profils — chart-container-donut height:300px max-width:380px -->
                    <VBox prefWidth="340"
                          style="-fx-background-color:white; -fx-background-radius:18;
                                 -fx-border-color:#e2e8f0; -fx-border-radius:18; -fx-border-width:1;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding:14 20; -fx-background-color:#f8fafc;
                                     -fx-background-radius:18 18 0 0;
                                     -fx-border-color:transparent transparent #e2e8f0 transparent;
                                     -fx-border-width:0 0 1 0;">
                            <Label text="🍩  Répartition — Profils types"
                                   style="-fx-font-weight:700; -fx-text-fill:#1e293b; -fx-font-size:13px;"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Label text="Donut Chart"
                                   style="-fx-background-color:#d1fae5; -fx-text-fill:#065f46;
                                          -fx-background-radius:50px; -fx-padding:3 12;
                                          -fx-font-size:11px; -fx-font-weight:700;"/>
                        </HBox>
                        <!-- chart-container-donut height:300px -->
                        <ScrollPane fitToWidth="true" prefHeight="340"
                                    style="-fx-background-color:transparent; -fx-border-width:0;">
                            <!--
                                vboxDonutChart est rempli dynamiquement par buildDonutChart() :
                                  [0] StackPane contenant le Canvas (roue)
                                  [1] VBox légende (position:'bottom')
                            -->
                            <VBox fx:id="vboxDonutChart" spacing="8" alignment="CENTER"
                                  style="-fx-padding:16 20 16 20;"/>
                        </ScrollPane>
                    </VBox>

                </HBox>

            </VBox>
            <!-- fin vboxContent -->

        </VBox>
    </ScrollPane>
</VBox>
