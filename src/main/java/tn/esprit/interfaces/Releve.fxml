<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ReleveController"
            prefWidth="1100" prefHeight="760"
            style="-fx-background-color:#f4f6fb;">

    <!-- ══════ HEADER ══════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-padding:14 24; -fx-background-color:white;
                     -fx-border-color:#e2e8f4; -fx-border-width:0 0 1 0;">

            <Button text="← Retour" onAction="#goBack"
                    style="-fx-background-color:transparent; -fx-text-fill:#5a6a8a;
                           -fx-font-size:13; -fx-cursor:hand;"/>

            <VBox spacing="2">
                <Label text="📄 Relevé de Notes &amp; Analyse IA"
                       style="-fx-font-size:19; -fx-font-weight:bold; -fx-text-fill:#1a2340;"/>
                <Label text="Importez votre relevé — l'IA extrait vos notes et recommande une filière"
                       style="-fx-font-size:12; -fx-text-fill:#5a6a8a;"/>
            </VBox>

            <Pane HBox.hgrow="ALWAYS"/>

            <HBox spacing="8" alignment="CENTER">
                <Button fx:id="btnNavUpload" text="📤 Upload" onAction="#goToUpload"
                        style="-fx-background-color:#eff6ff; -fx-text-fill:#2563eb;
                               -fx-font-weight:bold; -fx-background-radius:8;
                               -fx-border-color:#bfdbfe; -fx-border-radius:8;
                               -fx-padding:8 20; -fx-cursor:hand;"/>
                <Button fx:id="btnNavHistorique" text="📋 Historique" onAction="#goToHistorique"
                        style="-fx-background-color:transparent; -fx-text-fill:#5a6a8a;
                               -fx-background-radius:8; -fx-padding:8 20; -fx-cursor:hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ══════ CENTRE : 3 vues superposées ══════ -->
    <center>
        <StackPane>

            <!-- ── VUE 1 : UPLOAD (dans un ScrollPane pour scroller) ── -->
            <ScrollPane fx:id="uploadView" fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color:#f4f6fb; -fx-background:#f4f6fb;">
                <VBox alignment="TOP_CENTER" spacing="24" style="-fx-padding:40 32 40 32;">

                    <!-- Titre -->
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="📊 Analyse de votre Relevé de Notes"
                               style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:#1e40af;"/>
                        <Label text="Importez votre relevé (PDF ou image) — l'IA extrait vos notes et vous recommande la meilleure filière"
                               style="-fx-font-size:13; -fx-text-fill:#60a5fa;" wrapText="true"/>
                    </VBox>

                    <!-- Carte upload -->
                    <VBox maxWidth="680" spacing="20"
                          style="-fx-background-color:white; -fx-background-radius:20;
                                 -fx-border-color:rgba(96,165,250,0.35); -fx-border-radius:20;
                                 -fx-border-width:2; -fx-padding:32;
                                 -fx-effect:dropshadow(gaussian,rgba(37,99,235,0.13),20,0,0,6);">

                        <!-- Zone fichier drag & drop visuel -->
                        <VBox alignment="CENTER" spacing="14"
                              style="-fx-background-color:rgba(96,165,250,0.04);
                                     -fx-border-color:rgba(96,165,250,0.45); -fx-border-style:dashed;
                                     -fx-border-radius:16; -fx-border-width:2.5; -fx-padding:40;">
                            <Label text="📂" style="-fx-font-size:52;"/>
                            <Label text="Cliquez pour choisir votre relevé"
                                   style="-fx-font-size:15; -fx-font-weight:700; -fx-text-fill:#1e40af;"/>
                            <Label text="Formats acceptés : PDF, JPG, PNG, WEBP"
                                   style="-fx-font-size:12; -fx-text-fill:#93c5fd;"/>
                            <Button fx:id="btnChoisirFichier" text="📁 Choisir un fichier"
                                    onAction="#choisirFichier"
                                    style="-fx-background-color:linear-gradient(to right,#3b82f6,#60a5fa);
                                           -fx-text-fill:white; -fx-font-weight:700; -fx-font-size:14;
                                           -fx-background-radius:12; -fx-padding:12 32; -fx-cursor:hand;
                                           -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.35),10,0,0,3);"/>
                            <Label fx:id="labelFichierChoisi" text="Aucun fichier choisi"
                                   style="-fx-text-fill:#3b82f6; -fx-font-size:12; -fx-font-weight:600;"/>
                        </VBox>

                        <!-- Ce que l'IA analyse -->
                        <VBox spacing="12"
                              style="-fx-background-color:rgba(59,130,246,0.05);
                                     -fx-background-radius:14; -fx-padding:18;">
                            <Label text="🤖 Ce que l'IA va analyser :"
                                   style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#1e40af;"/>
                            <GridPane hgap="20" vgap="10">
                                <Label text="📊 Vos notes par matière"    style="-fx-text-fill:#3b82f6; -fx-font-size:13;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label text="⚖️ Calcul pondéré par coeff" style="-fx-text-fill:#3b82f6; -fx-font-size:13;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="🎯 Score par filière"        style="-fx-text-fill:#3b82f6; -fx-font-size:13;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label text="🏆 Filière recommandée"      style="-fx-text-fill:#3b82f6; -fx-font-size:13;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="💪 Vos points forts"         style="-fx-text-fill:#3b82f6; -fx-font-size:13;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <Label text="💡 Conseils personnalisés"   style="-fx-text-fill:#3b82f6; -fx-font-size:13;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            </GridPane>
                        </VBox>

                        <!-- Bouton analyser (activé après sélection fichier) -->
                        <Button fx:id="btnAnalyser"
                                text="🔍 Analyser mon relevé avec l'IA"
                                onAction="#lancerAnalyse" disable="true" maxWidth="Infinity"
                                style="-fx-background-color:linear-gradient(to right,#3b82f6,#60a5fa);
                                       -fx-text-fill:white; -fx-font-weight:800; -fx-font-size:15;
                                       -fx-background-radius:14; -fx-padding:15 0; -fx-cursor:hand;
                                       -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.4),14,0,0,4);"/>

                        <!-- Loading -->
                        <HBox fx:id="loadingBox" alignment="CENTER" spacing="14"
                              visible="false" managed="false"
                              style="-fx-background-color:rgba(59,130,246,0.07);
                                     -fx-background-radius:12; -fx-padding:16;">
                            <Label text="⚙️" style="-fx-font-size:26;"/>
                            <VBox spacing="3">
                                <Label fx:id="labelLoading"
                                       text="L'IA analyse votre relevé..."
                                       style="-fx-text-fill:#1e40af; -fx-font-weight:700; -fx-font-size:14;"/>
                                <Label text="Cela peut prendre 10 à 30 secondes, veuillez patienter"
                                       style="-fx-text-fill:#60a5fa; -fx-font-size:12;"/>
                            </VBox>
                        </HBox>

                    </VBox>

                    <!-- Lien historique bas de page -->
                    <Button text="📋 Voir mes analyses précédentes →"
                            onAction="#goToHistorique"
                            style="-fx-background-color:transparent; -fx-text-fill:#60a5fa;
                                   -fx-font-size:13; -fx-cursor:hand; -fx-border-color:transparent;
                                   -fx-underline:true;"/>

                </VBox>
            </ScrollPane>

            <!-- ── VUE 2 : RÉSULTATS ── -->
            <ScrollPane fx:id="resultView" fitToWidth="true" hbarPolicy="NEVER"
                        visible="false" managed="false"
                        style="-fx-background-color:#f4f6fb; -fx-background:#f4f6fb;">
                <VBox spacing="18" style="-fx-padding:28 36 36 36; -fx-background-color:#f4f6fb;">

                    <!-- Header résultats -->
                    <VBox alignment="CENTER" spacing="14"
                          style="-fx-background-color:white; -fx-background-radius:20;
                                 -fx-border-color:rgba(96,165,250,0.3); -fx-border-radius:20;
                                 -fx-border-width:2; -fx-padding:28;
                                 -fx-effect:dropshadow(gaussian,rgba(37,99,235,0.13),16,0,0,5);">
                        <Label text="🎓 Résultats de l'Analyse IA"
                               style="-fx-font-size:22; -fx-font-weight:800; -fx-text-fill:#1e40af;"/>
                        <HBox alignment="CENTER" spacing="32">
                            <VBox alignment="CENTER" spacing="5"
                                  style="-fx-background-color:linear-gradient(to right,#3b82f6,#60a5fa);
                                         -fx-background-radius:16; -fx-padding:18 36;">
                                <Label text="Moyenne générale"
                                       style="-fx-text-fill:rgba(255,255,255,0.85); -fx-font-size:12;"/>
                                <Label fx:id="resMoyenne" text="—"
                                       style="-fx-font-size:28; -fx-font-weight:800; -fx-text-fill:white;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="5"
                                  style="-fx-background-color:white; -fx-background-radius:16;
                                         -fx-border-color:#e2e8f4; -fx-border-radius:16; -fx-padding:18 36;">
                                <Label text="Mention"
                                       style="-fx-text-fill:#5a6a8a; -fx-font-size:12;"/>
                                <Label fx:id="resMention" text="—"
                                       style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:#2563eb;"/>
                            </VBox>
                        </HBox>
                        <Label fx:id="resFiliereReco" text="—"
                               style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#059669;"/>
                    </VBox>

                    <!-- Points forts / faibles -->
                    <HBox spacing="16">
                        <VBox fx:id="resPointsForts" spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color:rgba(16,185,129,0.07);
                                     -fx-border-color:rgba(16,185,129,0.3); -fx-border-radius:16;
                                     -fx-border-width:2; -fx-background-radius:16; -fx-padding:16;"/>
                        <VBox fx:id="resPointsFaibles" spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color:rgba(239,68,68,0.05);
                                     -fx-border-color:rgba(239,68,68,0.2); -fx-border-radius:16;
                                     -fx-border-width:2; -fx-background-radius:16; -fx-padding:16;"/>
                    </HBox>

                    <!-- Table des notes -->
                    <VBox spacing="10"
                          style="-fx-background-color:white; -fx-background-radius:18;
                                 -fx-border-color:rgba(96,165,250,0.3); -fx-border-radius:18;
                                 -fx-border-width:2; -fx-padding:18;
                                 -fx-effect:dropshadow(gaussian,rgba(37,99,235,0.1),12,0,0,4);">
                        <Label text="📝 Notes Détectées depuis votre Relevé"
                               style="-fx-font-size:16; -fx-font-weight:700; -fx-text-fill:#1e40af;"/>
                        <TableView fx:id="notesTable" prefHeight="230"
                                   style="-fx-background-color:transparent; -fx-border-color:transparent;">
                            <columns>
                                <TableColumn fx:id="colMatiere"  text="Matière"     prefWidth="280"/>
                                <TableColumn fx:id="colNote"     text="Note"        prefWidth="120"/>
                                <TableColumn fx:id="colCoeff"    text="Coefficient" prefWidth="110"/>
                                <TableColumn fx:id="colDomaine"  text="Domaine"     prefWidth="130"/>
                                <TableColumn fx:id="colNiveau"   text="Niveau"      prefWidth="110"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                    <!-- Scores par filière -->
                    <VBox spacing="12"
                          style="-fx-background-color:white; -fx-background-radius:18;
                                 -fx-border-color:rgba(96,165,250,0.3); -fx-border-radius:18;
                                 -fx-border-width:2; -fx-padding:18;
                                 -fx-effect:dropshadow(gaussian,rgba(37,99,235,0.1),12,0,0,4);">
                        <Label text="🎯 Score de Compatibilité par Filière"
                               style="-fx-font-size:16; -fx-font-weight:700; -fx-text-fill:#1e40af;"/>
                        <VBox fx:id="resScoresFilieres" spacing="10"/>
                    </VBox>

                    <!-- Conseil IA -->
                    <VBox spacing="10"
                          style="-fx-background-color:rgba(59,130,246,0.06);
                                 -fx-border-color:#60a5fa; -fx-border-radius:16;
                                 -fx-border-width:2; -fx-background-radius:16; -fx-padding:18;">
                        <Label text="💡 Conseil personnalisé de l'IA"
                               style="-fx-font-size:14; -fx-font-weight:700; -fx-text-fill:#1e40af;"/>
                        <Label fx:id="resConseil" text="—"
                               style="-fx-text-fill:#1e40af; -fx-font-size:13;" wrapText="true"/>
                    </VBox>

                    <!-- Boutons d'action -->
                    <HBox spacing="12" alignment="CENTER">
                        <Button text="📄 Nouvelle analyse" onAction="#nouvelleAnalyse"
                                style="-fx-background-color:linear-gradient(to right,#3b82f6,#60a5fa);
                                       -fx-text-fill:white; -fx-font-weight:700; -fx-font-size:13;
                                       -fx-background-radius:12; -fx-padding:12 28; -fx-cursor:hand;"/>
                        <Button text="📋 Historique" onAction="#goToHistorique"
                                style="-fx-background-color:white; -fx-text-fill:#1e40af; -fx-font-weight:700;
                                       -fx-font-size:13; -fx-background-radius:12; -fx-padding:12 28;
                                       -fx-border-color:rgba(96,165,250,0.4); -fx-border-radius:12; -fx-cursor:hand;"/>
                    </HBox>

                </VBox>
            </ScrollPane>

            <!-- ── VUE 3 : HISTORIQUE ── -->
            <VBox fx:id="historiqueView" visible="false" managed="false"
                  style="-fx-background-color:#f4f6fb; -fx-padding:24 32;">

                <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding:0 0 16 0;">
                    <Label text="📋 Mes Analyses de Relevés"
                           style="-fx-font-size:22; -fx-font-weight:800; -fx-text-fill:#1e40af;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nouvelle Analyse" onAction="#goToUpload"
                            style="-fx-background-color:linear-gradient(to right,#3b82f6,#60a5fa);
                                   -fx-text-fill:white; -fx-font-weight:700; -fx-background-radius:10;
                                   -fx-padding:9 20; -fx-cursor:hand;"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color:transparent; -fx-background:transparent;">
                    <VBox fx:id="historiqueListBox" spacing="12" style="-fx-padding:4 4 24 4;"/>
                </ScrollPane>

            </VBox>

        </StackPane>
    </center>

</BorderPane>
