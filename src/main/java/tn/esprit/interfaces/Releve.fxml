<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ReleveController"
            prefWidth="1000" prefHeight="700"
            style="-fx-background-color: #f4f6fb;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 16 24; -fx-background-color: white; -fx-border-color: #e2e8f4; -fx-border-width: 0 0 1 0;">
            <Button text="← Retour" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13;"/>
            <VBox spacing="2">
                <Label text="Relevé de notes" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <Label text="Vue synthétique et lisible des résultats" style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
            </VBox>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Exporter PDF" onAction="#exportPDF" style="-fx-background-color: transparent; -fx-text-fill: #2563eb; -fx-border-color: #bfdbfe; -fx-border-radius: 8; -fx-padding: 8 18;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 20 24 24 24; -fx-background-color: #f4f6fb;">
            <HBox spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="4" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 14;">
                    <Label text="Moyenne générale" style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                    <Label fx:id="moyenneGenerale" text="--" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="4" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 14;">
                    <Label text="Mention" style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                    <Label fx:id="mentionLabel" text="--" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="4" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 14;">
                    <Label text="Niveau" style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                    <Label fx:id="niveauLabel" text="--" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="4" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 14;">
                    <Label text="Filière" style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                    <Label fx:id="filiereLabel" text="--" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                </VBox>
            </HBox>

            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e2e8f4; -fx-border-radius: 16; -fx-padding: 16;" VBox.vgrow="ALWAYS">
                <Label text="Détail des notes" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <TableView fx:id="notesTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMatiere" text="Matière" prefWidth="360"/>
                        <TableColumn fx:id="colNote" text="Note" prefWidth="120"/>
                        <TableColumn fx:id="colCoeff" text="Coefficient" prefWidth="140"/>
                        <TableColumn fx:id="colMention" text="Mention" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

</BorderPane>
