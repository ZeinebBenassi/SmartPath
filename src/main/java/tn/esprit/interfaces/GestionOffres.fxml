<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    GestionOffres.fxml - Page enfant (chargée dans contentArea Admin)
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.GestionOffresController"
      spacing="16"
      style="-fx-background-color: #f4f6fb; -fx-padding: 0;">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Offres de stage"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Rechercher..."
                   style="-fx-background-color: white; -fx-border-color: #dce5f6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 14;"
                   prefWidth="220"/>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <!-- Liste des offres -->
        <VBox prefWidth="360" spacing="10"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 14;">
            <Label text="Liste des offres"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
            <ListView fx:id="offresList" VBox.vgrow="ALWAYS"/>
        </VBox>

        <!-- Détail de l'offre -->
        <VBox spacing="14" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 18;">
            <Label fx:id="offreTitre" text="Sélectionnez une offre"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
            <HBox spacing="12">
                <Label fx:id="offreEntreprise" text="" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                <Label fx:id="offreDuree"      text="" style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
            </HBox>
            <Label fx:id="offreDescription" wrapText="true"
                   style="-fx-font-size: 12; -fx-text-fill: #475569; -fx-background-color: #f8fbff; -fx-background-radius: 12; -fx-border-color: #e3ecfa; -fx-border-radius: 12; -fx-padding: 12;" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>

</VBox>
