<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.GestionOffresController"
      spacing="0"
      style="-fx-background-color: #f4f7fb;">

    <!-- Barre de controles -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white;
                 -fx-padding: 14 20;
                 -fx-border-color: transparent transparent #e2e8f0 transparent;
                 -fx-border-width: 0 0 1 0;">

        <Label text="Offres de stage"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnRetour" text="← Retour" onAction="#goBack"
                style="-fx-background-color: #2563eb;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 12;
                       -fx-background-radius: 8;
                       -fx-padding: 8 16;
                       -fx-cursor: hand;"/>
    </HBox>

    <!-- Contenu vide -->
    <VBox alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS"
          style="-fx-background-color: #f4f7fb; -fx-padding: 50;">
        <Label text="📋"
               style="-fx-font-size: 48;"/>
        <Label text="Offres de stage"
               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
        <Label text="Aucune offre de stage disponible pour le moment."
               style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
    </VBox>

</VBox>
