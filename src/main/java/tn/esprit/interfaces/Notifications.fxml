<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="tn.esprit.controllers.NotificationsController"
      style="-fx-padding:0;">

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-padding:0 0 12 0; -fx-border-color:#E2E8F0; -fx-border-width:0 0 1 0;">

        <Label text="🔔" style="-fx-font-size:24px;"/>
        <Label fx:id="lblCount" text="Notifications"
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1E293B;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnMarkAll" text="✔ Tout marquer lu"
                onAction="#handleMarkAll"
                style="-fx-background-color:#10B981; -fx-text-fill:white; -fx-font-weight:bold;
                       -fx-font-size:12px; -fx-background-radius:10; -fx-padding:8 18; -fx-cursor:hand;"/>
    </HBox>

    <!-- Liste scrollable -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent; -fx-background-color:transparent; -fx-border-color:transparent;">
        <VBox fx:id="vboxNotifications" spacing="10"
              style="-fx-padding:4 0;"/>
    </ScrollPane>

</VBox>
