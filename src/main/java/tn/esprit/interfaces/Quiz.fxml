<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.QuizController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #f4f6fb;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 16 24; -fx-background-color: white; -fx-border-color: #e2e8f4; -fx-border-width: 0 0 1 0;">
            <Button text="← Retour" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13;"/>
            <Label text="Quiz d'orientation" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="progressLabel" text="À faire" style="-fx-text-fill: #5a6a8a; -fx-font-size: 13;"/>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 24;">
            <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 40;">
                <Label text="À faire" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                <Label text="Quiz Étudiant en préparation" style="-fx-font-size: 14; -fx-text-fill: #5a6a8a;"/>
            </VBox>

            <VBox fx:id="introView" visible="false" managed="false"/>
            <VBox fx:id="questionView" visible="false" managed="false"/>
            <VBox fx:id="resultView" visible="false" managed="false"/>
            <ProgressBar fx:id="progressBar" visible="false" managed="false"/>
            <Label fx:id="questionNum" visible="false" managed="false"/>
            <Label fx:id="questionText" visible="false" managed="false"/>
            <VBox fx:id="answersBox" visible="false" managed="false"/>
            <Button fx:id="btnPrev" visible="false" managed="false"/>
            <Button fx:id="btnNext" visible="false" managed="false"/>
            <Label fx:id="profileTypeLabel" visible="false" managed="false"/>
            <ListView fx:id="recommendationsList" visible="false" managed="false"/>
        </StackPane>
    </center>

</BorderPane>

