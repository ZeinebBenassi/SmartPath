<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.QuizController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #f4f6fb;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 16 24; -fx-background-color: white; -fx-border-color: #e2e8f4; -fx-border-width: 0 0 1 0;">
            <Button text="← Retour" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13;"/>
            <Label text="Quiz d'orientation" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="progressLabel" text="À faire" style="-fx-text-fill: #5a6a8a; -fx-font-size: 13;"/>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 24;">
            <VBox fx:id="introView" alignment="CENTER" spacing="16" maxWidth="760"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 36;">
                <Label text="Quiz d'orientation" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <Label wrapText="true" text="Le module de quiz sera connecté à des données réelles plus tard. Pour le moment, l'interface reste propre et sans contenu de démonstration." style="-fx-font-size: 13; -fx-text-fill: #5a6a8a; -fx-text-alignment: center;"/>
                <HBox spacing="12">
                    <Label text="" style="-fx-font-size: 28;"/>
                    <Label text="" style="-fx-font-size: 28;"/>
                    <Label text="" style="-fx-font-size: 28;"/>
                </HBox>
                <Button text="Quiz non disponible" onAction="#startQuiz"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 8;"/>
            </VBox>

            <VBox fx:id="questionView" visible="false" managed="false" spacing="14" maxWidth="760"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 22;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="questionNum" text="Question 1" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <ProgressBar fx:id="progressBar" prefWidth="220" progress="0.1"/>
                </HBox>
                <Label fx:id="questionText" wrapText="true" text="Question" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <VBox fx:id="answersBox" spacing="10" VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button fx:id="btnPrev" text="← Précédent" onAction="#prevQuestion"
                            style="-fx-background-color: #f1f5f9; -fx-text-fill: #334155; -fx-font-size: 12; -fx-padding: 8 12; -fx-background-radius: 8;"/>
                    <Button fx:id="btnNext" text="Suivant →" onAction="#nextQuestion"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 8 12; -fx-background-radius: 8;"/>
                </HBox>
            </VBox>

            <VBox fx:id="resultView" visible="false" managed="false" alignment="CENTER" spacing="14" maxWidth="760"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 26;">
                <Label text="Résultat" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <Label fx:id="profileTypeLabel" text="Profil" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                <Label text="Recommandations" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <ListView fx:id="recommendationsList" prefHeight="180" prefWidth="500"/>
                <HBox spacing="10">
                    <Button text="Recommencer" onAction="#restartQuiz"
                            style="-fx-background-color: #f1f5f9; -fx-text-fill: #334155; -fx-font-size: 12; -fx-padding: 8 12; -fx-background-radius: 8;"/>
                    <Button text="Voir mon profil" onAction="#voirProfil"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 8 12; -fx-background-radius: 8;"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
