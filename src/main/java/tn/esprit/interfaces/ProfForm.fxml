<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.ProfFormController"
      prefWidth="660" spacing="0" style="-fx-background-color:#FFFFFF;">

    <!-- Header -->
    <VBox style="-fx-background-color:#FFFFFF;-fx-padding:24 32 16 32;-fx-border-color:transparent transparent #E2E8F0 transparent;-fx-border-width:0 0 1 0;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="🎓" style="-fx-font-size:22px;"/>
            <Label fx:id="lblTitle" text="Créer un nouveau professeur"
                   style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
        </HBox>
        <Label text="Remplissez les informations ci-dessous pour ajouter un professeur"
               style="-fx-font-size:12px;-fx-text-fill:#94A3B8;-fx-padding:4 0 0 0;"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:#FFFFFF;-fx-background-color:#FFFFFF;-fx-border-width:0;">
        <VBox spacing="0" style="-fx-padding:24 32 8 32;">

            <!-- Section 1 -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:0 0 6 0;">
                <Label text="👤" style="-fx-font-size:16;-fx-text-fill:#5B21B6;"/>
                <Label text="Informations personnelles" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#5B21B6;"/>
            </HBox>
            <Separator/>
            <VBox spacing="14" style="-fx-padding:16 0 24 0;">
                <HBox spacing="16">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Nom" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                        <TextField fx:id="txtNom" promptText="Nom"
                                   style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Prenom" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                        <TextField fx:id="txtPrenom" promptText="Prenom"
                                   style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                    </VBox>
                </HBox>
                <HBox spacing="16">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Email" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                        <TextField fx:id="txtEmail" promptText="Email"
                                   style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Date de naissance" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                        <DatePicker fx:id="dpNaissance" promptText="jj/mm/aaaa" maxWidth="Infinity"
                                    style="-fx-background-color:#F9FAFB;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Section 2 -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:0 0 6 0;">
                <Label text="💼" style="-fx-font-size:16;-fx-text-fill:#B45309;"/>
                <Label text="Informations professionnelles et contact" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#B45309;"/>
            </HBox>
            <Separator/>
            <VBox spacing="14" style="-fx-padding:16 0 24 0;">
                <HBox spacing="16">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Specialite" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                        <TextField fx:id="txtSpecialite" promptText="Specialite"
                                   style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="CIN" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                        <TextField fx:id="txtCIN" promptText="CIN"
                                   style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                    </VBox>
                </HBox>
                <VBox spacing="5" maxWidth="290">
                    <Label text="Telephone" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                    <TextField fx:id="txtTelephone" promptText="Telephone"
                               style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Adresse" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                    <TextField fx:id="txtAdresse" promptText="Adresse"
                               style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                </VBox>
            </VBox>

            <!-- Section 3 -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:0 0 6 0;">
                <Label text="🔒" style="-fx-font-size:16;"/>
                <Label text="Sécurité du compte" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            </HBox>
            <Separator/>
            <VBox spacing="14" style="-fx-padding:16 0 8 0;">
                <HBox spacing="16">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblPasswordHint" text="Mot de passe" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                        <PasswordField fx:id="tfPassword" promptText="Mot de passe"
                                       style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                        <Label text="Minimum 6 caractères" style="-fx-font-size:10px;-fx-text-fill:#9CA3AF;-fx-font-style:italic;"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Confirmer le mot de passe" style="-fx-font-size:13px;-fx-text-fill:#374151;"/>
                        <PasswordField fx:id="tfConfirm" promptText="Confirmer le mot de passe"
                                       style="-fx-background-color:#F9FAFB;-fx-background-radius:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-border-width:1;-fx-padding:9 12;-fx-font-size:13px;"/>
                    </VBox>
                </HBox>
                <Label fx:id="lblErrors" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-text-fill:#DC2626;-fx-font-size:11px;-fx-font-weight:bold;-fx-background-color:#FEF2F2;-fx-background-radius:6;-fx-padding:8 12;"/>
            </VBox>
        </VBox>
    </ScrollPane>

    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-background-color:#F8FAFC;-fx-padding:16 32;-fx-border-color:#E2E8F0 transparent transparent transparent;-fx-border-width:1;">
        <Button fx:id="btnCancel" text="Annuler" onAction="#handleCancel"
                style="-fx-background-color:#FFFFFF;-fx-text-fill:#64748B;-fx-background-radius:8;-fx-padding:9 22;-fx-cursor:hand;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;"/>
        <Button fx:id="btnSave"   text="Enregistrer" onAction="#handleSave"
                style="-fx-background-color:#2563EB;-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13px;-fx-background-radius:8;-fx-padding:9 22;-fx-cursor:hand;"/>
    </HBox>
</VBox>