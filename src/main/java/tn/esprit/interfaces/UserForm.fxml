<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.UserFormController"
      prefWidth="520" spacing="0" style="-fx-background-color:#FFFFFF;">
    <HBox style="-fx-background-color:linear-gradient(to right,#2563eb,#3b82f6);-fx-padding:20 24;">
        <Label fx:id="lblTitle" text="➕  Nouvel Utilisateur"
               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:white;"/>
    </HBox>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-background:#FFFFFF;-fx-border-width:0;">
        <VBox spacing="16" style="-fx-padding:24 28;">
            <HBox spacing="14">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Nom *" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <TextField fx:id="txtNom" promptText="Nom"
                               style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Prénom *" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <TextField fx:id="txtPrenom" promptText="Prénom"
                               style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;"/>
                </VBox>
            </HBox>
            <HBox spacing="14">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Email *" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <TextField fx:id="txtEmail" promptText="Email"
                               style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Rôle *" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <ComboBox fx:id="cbType" maxWidth="Infinity"
                              style="-fx-font-size:13px;-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;"/>
                </VBox>
            </HBox>
            <HBox spacing="14">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblPassword" text="Mot de passe *" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <PasswordField fx:id="tfPassword" promptText="Mot de passe"
                                   style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;"/>
                    <Label text="Minimum 6 caractères" style="-fx-font-size:10px;-fx-text-fill:#94a3b8;-fx-font-style:italic;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Confirmer le mot de passe" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <PasswordField fx:id="tfConfirm" promptText="Confirmer"
                                   style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;"/>
                </VBox>
            </HBox>
            <Separator/>
            <HBox spacing="14">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="CIN" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <TextField fx:id="txtCIN" promptText="12345678"
                               style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Téléphone" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <TextField fx:id="txtTelephone" promptText="55123456"
                               style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;"/>
                </VBox>
            </HBox>
            <VBox spacing="5">
                <Label text="Adresse" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                <TextField fx:id="txtAdresse" promptText="Adresse"
                           style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;"/>
            </VBox>
            <Label fx:id="lblErrors" text="" wrapText="true" visible="false" managed="false"
                   style="-fx-text-fill:#e53e3e;-fx-font-size:11px;-fx-font-weight:bold;-fx-background-color:#fff5f5;-fx-background-radius:8;-fx-padding:8 12;"/>
        </VBox>
    </ScrollPane>
    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-background-color:#F8FAFC;-fx-padding:16 24;-fx-border-color:#E2E8F0 transparent transparent transparent;-fx-border-width:1;">
        <Button fx:id="btnCancel" text="Annuler" onAction="#handleCancel"
                style="-fx-background-color:#F8FAFC;-fx-text-fill:#64748B;-fx-background-radius:20;-fx-padding:9 20;-fx-cursor:hand;-fx-border-color:#E2E8F0;-fx-border-radius:20;-fx-border-width:1;"/>
        <Button fx:id="btnSave" text="💾  Enregistrer" onAction="#handleSave"
                style="-fx-background-color:#2563eb;-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13px;-fx-background-radius:20;-fx-padding:9 20;-fx-cursor:hand;"/>
    </HBox>
</VBox>