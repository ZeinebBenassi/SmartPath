<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.UserFormController"
      prefWidth="520" style="-fx-background-color: #FFFFFF;" spacing="0">

    <HBox style="-fx-background-color: linear-gradient(to right,#2563eb,#3b82f6); -fx-padding: 20 24;">
        <Label fx:id="lblTitle" text="➕  Nouvel Utilisateur"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: #FFFFFF; -fx-border-width: 0;">
        <VBox spacing="16" style="-fx-padding: 24 28;">

            <!-- Identité -->
            <HBox spacing="14">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Nom *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="txtNom" promptText="Ex : Dupont"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                      -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-padding: 8 12; -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Prénom *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="txtPrenom" promptText="Ex : Jean"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                      -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-padding: 8 12; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <!-- Email et Type -->
            <HBox spacing="14">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Email *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="txtEmail" promptText="Ex : jean@example.com"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                      -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-padding: 8 12; -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Type *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <ComboBox fx:id="cbType" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <!-- Mot de passe -->
            <VBox spacing="5">
                <Label fx:id="lblPassword" text="Mot de passe *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <PasswordField fx:id="tfPassword" promptText="Entrer le mot de passe"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                      -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-padding: 8 12; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Divider -->
            <Separator style="-fx-border-color: #E2E8F0;"/>

            <!-- CIN et Téléphone -->
            <HBox spacing="14">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="CIN" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="txtCIN" promptText="Ex : 12345678"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                      -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-padding: 8 12; -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Téléphone" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="txtTelephone" promptText="Ex : +216 98 123 456"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                      -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-padding: 8 12; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <!-- Adresse -->
            <VBox spacing="5">
                <Label text="Adresse" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="txtAdresse" promptText="Ex : 123 Rue de la Paix, Tunis"
                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                  -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                  -fx-padding: 8 12; -fx-font-size: 13px;"/>
            </VBox>

        </VBox>
    </ScrollPane>

    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-background-color: #F8FAFC; -fx-padding: 16 24;
                 -fx-border-color: #E2E8F0 transparent transparent transparent; -fx-border-width: 1;">
        <Button fx:id="btnCancel" text="Annuler" onAction="#handleCancel"
                style="-fx-background-color: #F8FAFC; -fx-text-fill: #64748B; -fx-background-radius: 20;
                       -fx-padding: 9 20; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-border-width: 1;"/>
        <Button fx:id="btnSave" text="💾  Enregistrer" onAction="#handleSave"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-font-size: 13px; -fx-background-radius: 20; -fx-padding: 9 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>
