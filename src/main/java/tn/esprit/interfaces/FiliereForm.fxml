<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.FiliereFormController"
      prefWidth="520" style="-fx-background-color: #FFFFFF;" spacing="0">

    <HBox style="-fx-background-color: linear-gradient(to right,#6366F1,#8B5CF6); -fx-padding: 20 24;">
        <Label fx:id="lblTitle" text="➕  Nouvelle Filière"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: #FFFFFF; -fx-border-width: 0;">
        <VBox spacing="16" style="-fx-padding: 24 28;">

            <VBox spacing="5">
                <Label text="Nom de la filière *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="txtNom" promptText="Ex : Génie Logiciel" maxWidth="Infinity"
                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                  -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                  -fx-padding: 8 12; -fx-font-size: 13px;"/>
            </VBox>

            <HBox spacing="14">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Catégorie *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <ComboBox fx:id="cbCategorie" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Niveau *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <ComboBox fx:id="cbNiveau" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Icône" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <ComboBox fx:id="cbIcon" prefWidth="80"/>
                </VBox>
            </HBox>

            <VBox spacing="5">
                <Label text="Description" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextArea fx:id="txtDescription" promptText="Description de la filière..." prefRowCount="3" wrapText="true"
                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                 -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                 -fx-padding: 8 12; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Débouchés professionnels" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextArea fx:id="txtDebouches" promptText="Ex : Développeur, Architecte..." prefRowCount="2" wrapText="true"
                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                 -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                 -fx-padding: 8 12; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Image de la filière (optionnelle)" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="txtImage" promptText="Chemin non sélectionné..." HBox.hgrow="ALWAYS"
                               editable="false"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                      -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-padding: 8 12; -fx-font-size: 12px;"/>
                    <Button text="📁 Choisir" onAction="#handleChooseImage"
                            style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                    <Button text="✕" onAction="#handleRemoveImage"
                            style="-fx-background-color: #FEE2E2; -fx-text-fill: #EF4444;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 12; -fx-cursor: hand;"/>
                </HBox>
                <StackPane fx:id="imgPreviewPane" prefHeight="120" maxWidth="Infinity"
                           style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;
                                  -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;">
                    <Label fx:id="lblNoImage" text="Aucune image sélectionnée"
                           style="-fx-text-fill: #CBD5E1; -fx-font-size: 12px;"/>
                </StackPane>
            </VBox>

            <VBox spacing="5">
                <Label text="Compétences développées" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextArea fx:id="txtCompetences" promptText="Ex : Java, Spring Boot, SQL..." prefRowCount="2" wrapText="true"
                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;
                                 -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;
                                 -fx-padding: 8 12; -fx-font-size: 13px;"/>
            </VBox>
        </VBox>
    </ScrollPane>

    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-background-color: #F8FAFC; -fx-padding: 16 24;
                 -fx-border-color: #E2E8F0 transparent transparent transparent; -fx-border-width: 1;">
        <Button fx:id="btnCancel" text="Annuler" onAction="#handleCancel"
                style="-fx-background-color: #F8FAFC; -fx-text-fill: #64748B; -fx-background-radius: 20;
                       -fx-padding: 9 20; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-border-width: 1;"/>
        <Button fx:id="btnSave" text="💾  Enregistrer" onAction="#handleSave"
                style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-font-size: 13px; -fx-background-radius: 20; -fx-padding: 9 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>
