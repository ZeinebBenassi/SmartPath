<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane prefHeight="700" prefWidth="980"
           style="-fx-background-color: linear-gradient(to bottom right, #eef3ff, #f0f7ff);"
           xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/21"
           fx:controller="tn.esprit.controllers.RegisterController">

    <HBox alignment="CENTER" prefHeight="660" prefWidth="920"
          style="-fx-background-color: white; -fx-background-radius: 20;
                 -fx-border-color: #dce8fa; -fx-border-radius: 20; -fx-border-width: 1;">

        <!-- ── Panneau gauche ── -->
        <VBox alignment="CENTER" prefWidth="320" spacing="20"
              style="-fx-background-color: linear-gradient(to bottom right, #1e3a8a, #2563eb);
                     -fx-background-radius: 20 0 0 20; -fx-padding: 44;">

            <ImageView fitWidth="150" preserveRatio="true" smooth="true">
                <image><Image url="@/images/logo.png"/></image>
            </ImageView>

            <VBox spacing="8" alignment="CENTER">
                <Label text="Rejoignez SmartPath"
                       style="-fx-font-size: 19; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label wrapText="true" maxWidth="230" textAlignment="CENTER"
                       text="Créez votre compte étudiant et commencez votre parcours d'apprentissage."
                       style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.78); -fx-text-alignment: center;"/>
            </VBox>

            <!-- Conseils sécurité -->
            <VBox spacing="8" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 14 18;">
                <Label text="🔒 Conseils sécurité" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                <Label text="✓ Plus de 10 caractères"    style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 10;"/>
                <Label text="✓ Majuscules + minuscules"  style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 10;"/>
                <Label text="✓ Chiffres inclus"          style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 10;"/>
                <Label text="✓ Symboles (@, #, !, …)"   style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 10;"/>
            </VBox>

            <HBox alignment="CENTER" spacing="6" style="-fx-padding: 4 0 0 0;">
                <Circle radius="4" fill="white" opacity="0.4"/>
                <Circle radius="4" fill="white" opacity="0.4"/>
                <Circle radius="4" fill="white" opacity="0.9"/>
            </HBox>
        </VBox>

        <!-- ── Panneau droit ── -->
        <VBox alignment="CENTER" prefWidth="600" spacing="8"
              style="-fx-padding: 20 44;">

            <!-- Onglets -->
            <HBox maxWidth="460" spacing="0"
                  style="-fx-background-color: #f4f6fb; -fx-background-radius: 10;
                         -fx-border-color: #e2e8f4; -fx-border-radius: 10; -fx-border-width: 1;">
                <Button onAction="#goToLogin" prefHeight="36" prefWidth="230"
                        style="-fx-background-color: transparent; -fx-text-fill: #8898b8;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 9 0 0 9; -fx-cursor: hand;"
                        text="Connexion"/>
                <Button disable="true" prefHeight="36" prefWidth="230"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 0 9 9 0; -fx-cursor: default;"
                        text="Inscription"/>
            </HBox>

            <Label text="Créer un compte étudiant"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>

            <!-- Nom / Prénom -->
            <HBox maxWidth="460" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Nom"/>
                    <TextField fx:id="nomField" prefHeight="38" promptText="Votre nom"
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12; -fx-font-size: 13;"/>
                    <Label fx:id="nomError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Prenom"/>
                    <TextField fx:id="prenomField" prefHeight="38" promptText="Votre prenom"
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12; -fx-font-size: 13;"/>
                    <Label fx:id="prenomError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
                </VBox>
            </HBox>

            <!-- Email -->
            <VBox maxWidth="460" spacing="3">
                <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Adresse email"/>
                <TextField fx:id="emailField" prefHeight="38" promptText="exemple@email.com"
                           style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                  -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12; -fx-font-size: 13;"/>
                <Label fx:id="emailError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
            </VBox>

            <!-- CIN / Telephone -->
            <HBox maxWidth="460" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="CIN"/>
                    <TextField fx:id="cinField" prefHeight="38" promptText="12345678"
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12; -fx-font-size: 13;"/>
                    <Label fx:id="cinError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Telephone"/>
                    <TextField fx:id="telephoneField" prefHeight="38" promptText="+216 ..."
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12; -fx-font-size: 13;"/>
                    <Label fx:id="phoneError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
                </VBox>
            </HBox>

            <!-- Adresse / Date de naissance / Niveau -->
            <HBox maxWidth="460" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Adresse"/>
                    <TextField fx:id="adresseField" prefHeight="38" promptText="Votre adresse"
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12; -fx-font-size: 13;"/>
                    <Label fx:id="adresseError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Date de naissance"/>
                    <DatePicker fx:id="dateNaissancePicker" prefHeight="38"
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13;"/>
                    <Label fx:id="dateError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
                </VBox>
            </HBox>

            <!-- Niveau -->
            <VBox maxWidth="460" spacing="3">
                <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Niveau"/>
                <ComboBox fx:id="niveauCombo" prefHeight="38" prefWidth="460"
                          promptText="Choisir votre niveau"
                          style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13;"/>
                <Label fx:id="niveauError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
            </VBox>

            <!-- Photo de profil (optionnel) -->
            <VBox maxWidth="460" spacing="5"
                  style="-fx-background-color: #f7f9fc; -fx-background-radius: 8;
                         -fx-border-color: #e2e8f4; -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 10 14;">
                <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"
                       text="Photo de profil (optionnel)"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <ImageView fx:id="photoPreview"
                          fitWidth="52" fitHeight="52"
                          preserveRatio="true" smooth="true"
                          style="-fx-background-radius: 26;"/>
                    <VBox spacing="4">
                        <Button fx:id="choosePhotoBtn" onAction="#handleChoosePhoto"
                                prefHeight="30" prefWidth="180"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white;
                                       -fx-font-size: 11; -fx-font-weight: bold;
                                       -fx-background-radius: 7; -fx-cursor: hand;"
                                text="📷 Choisir une photo"/>
                        <Label fx:id="photoLabel"
                               style="-fx-font-size: 10; -fx-text-fill: #8898b8;"
                               text="Aucune image sélectionnée"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Mots de passe -->
            <HBox maxWidth="460" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Mot de passe"/>
                    <PasswordField fx:id="passwordField" prefHeight="38" promptText="Mot de passe..."
                                   style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12; -fx-font-size: 13;"/>
                    <Label fx:id="passwordError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Confirmation"/>
                    <PasswordField fx:id="confirmPasswordField" prefHeight="38" promptText="Confirmer..."
                                   style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12; -fx-font-size: 13;"/>
                    <Label fx:id="confirmError" style="-fx-font-size: 10; -fx-text-fill: #e94560;" text=""/>
                </VBox>
            </HBox>

            <!-- Indicateur de force mot de passe -->
            <VBox maxWidth="460" spacing="5"
                  style="-fx-background-color: #f7f9fc; -fx-background-radius: 8;
                         -fx-border-color: #e2e8f4; -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 8 12;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="Force :"
                           style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"/>
                    <Label fx:id="strengthLevel" text="—"
                           style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #b0b8c9;"/>
                </HBox>
                <ProgressBar fx:id="strengthBar"
                             maxWidth="Infinity" prefHeight="6" progress="0"
                             style="-fx-accent: #e2e8f0; -fx-background-color: #e2e8f0;
                                    -fx-background-radius: 3; -fx-border-width: 0; -fx-padding: 0;"/>
                <Label fx:id="strengthAdvice" text="" wrapText="true" maxWidth="420"
                       style="-fx-font-size: 10; -fx-text-fill: #8898b8;"/>
            </VBox>

            <!-- Message global -->
            <Label fx:id="messageLabel" maxWidth="460"
                   style="-fx-font-size: 12;" text="" wrapText="true"/>

            <!-- Bouton inscription -->
            <Button onAction="#handleRegister" prefHeight="42" prefWidth="460"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white;
                           -fx-font-size: 14; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-cursor: hand;"
                    text="Créer mon compte"/>

            <HBox alignment="CENTER" spacing="6">
                <Label style="-fx-text-fill: #8898b8; -fx-font-size: 12;" text="Déjà un compte ?"/>
                <Button onAction="#goToLogin"
                        style="-fx-background-color: transparent; -fx-text-fill: #2563eb;
                               -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"
                        text="Se connecter"/>
            </HBox>
        </VBox>
    </HBox>
</StackPane>
