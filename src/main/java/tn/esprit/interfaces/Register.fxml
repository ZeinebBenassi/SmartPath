<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane prefHeight="660" prefWidth="980"
           style="-fx-background-color: linear-gradient(to bottom right, #eef3ff, #f0f7ff);"
           xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/25"
           fx:controller="tn.esprit.controllers.RegisterController">

    <HBox alignment="CENTER" prefHeight="620" prefWidth="920"
          style="-fx-background-color: white; -fx-background-radius: 20;
                 -fx-border-color: #dce8fa; -fx-border-radius: 20; -fx-border-width: 1;">

        <!-- ── Panneau gauche ── -->
        <VBox alignment="CENTER" prefWidth="320" spacing="20"
              style="-fx-background-color: linear-gradient(to bottom right, #1e3a8a, #2563eb);
                     -fx-background-radius: 20 0 0 20; -fx-padding: 44;">

            <ImageView fitWidth="150" preserveRatio="true" smooth="true">
                <image><Image url="@/images/logo.png"/></image>
            </ImageView>

            <VBox spacing="8" alignment="CENTER">
                <Label text="Rejoignez SmartPath"
                       style="-fx-font-size: 19; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label wrapText="true" maxWidth="230" textAlignment="CENTER"
                       text="Créez votre compte étudiant et commencez votre parcours d'apprentissage."
                       style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.78); -fx-text-alignment: center;"/>
            </VBox>

            <HBox alignment="CENTER" spacing="6" style="-fx-padding: 10 0 0 0;">
                <Circle radius="4" fill="white" opacity="0.4"/>
                <Circle radius="4" fill="white" opacity="0.4"/>
                <Circle radius="4" fill="white" opacity="0.9"/>
            </HBox>
        </VBox>

        <!-- ── Panneau droit ── -->
        <VBox alignment="CENTER" prefWidth="600" spacing="14"
              style="-fx-padding: 32 48;">

            <!-- Onglets -->
            <HBox maxWidth="460" spacing="0"
                  style="-fx-background-color: #f4f6fb; -fx-background-radius: 10;
                         -fx-border-color: #e2e8f4; -fx-border-radius: 10; -fx-border-width: 1;">
                <Button onAction="#goToLogin" prefHeight="36" prefWidth="230"
                        style="-fx-background-color: transparent; -fx-text-fill: #8898b8;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 9 0 0 9; -fx-cursor: hand;"
                        text="Connexion"/>
                <Button disable="true" prefHeight="36" prefWidth="230"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 0 9 9 0; -fx-cursor: default;"
                        text="Inscription"/>
            </HBox>

            <Label text="Créer un compte étudiant"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>

            <!-- Nom / Prénom -->
            <HBox maxWidth="460" spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Nom"/>
                    <TextField fx:id="nomField" prefHeight="40" promptText="Votre nom"
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Prénom"/>
                    <TextField fx:id="prenomField" prefHeight="40" promptText="Votre prénom"
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13;"/>
                </VBox>
            </HBox>

            <!-- Email -->
            <VBox maxWidth="460" spacing="5">
                <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Adresse email"/>
                <TextField fx:id="emailField" prefHeight="40" promptText="exemple@email.com"
                           style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                  -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13;"/>
            </VBox>

            <!-- CIN / Téléphone -->
            <HBox maxWidth="460" spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="CIN"/>
                    <TextField fx:id="cinField" prefHeight="40" promptText="12345678"
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Téléphone"/>
                    <TextField fx:id="telephoneField" prefHeight="40" promptText="+216 ..."
                               style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13;"/>
                </VBox>
            </HBox>

            <!-- Mots de passe -->
            <HBox maxWidth="460" spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Mot de passe"/>
                    <PasswordField fx:id="passwordField" prefHeight="40" promptText="••••••••"
                                   style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;" text="Confirmation"/>
                    <PasswordField fx:id="confirmPasswordField" prefHeight="40" promptText="••••••••"
                                   style="-fx-background-color: #f7f9fc; -fx-border-color: #e2e8f4;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13;"/>
                </VBox>
            </HBox>

            <!-- Message -->
            <Label fx:id="messageLabel" maxWidth="460"
                   style="-fx-font-size: 12;" text="" wrapText="true"/>

            <!-- Bouton -->
            <Button onAction="#handleRegister" prefHeight="44" prefWidth="460"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white;
                           -fx-font-size: 14; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-cursor: hand;"
                    text="Créer mon compte"/>

            <!-- Lien connexion -->
            <HBox alignment="CENTER" spacing="6">
                <Label style="-fx-text-fill: #8898b8; -fx-font-size: 12;" text="Déjà un compte ?"/>
                <Button onAction="#goToLogin"
                        style="-fx-background-color: transparent; -fx-text-fill: #2563eb;
                               -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"
                        text="Se connecter"/>
            </HBox>
        </VBox>
    </HBox>
</StackPane>
