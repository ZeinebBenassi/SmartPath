<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    ⚠️  xmlns="http://javafx.com/javafx/21"  ← version corrigée (était 25)
    Cela supprime le warning :
      "Loading FXML document with JavaFX API of version 25 by JavaFX runtime of version 21"
-->
<BorderPane prefHeight="700" prefWidth="1200" styleClass="app-bg" stylesheets="@smartpath.css"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="tn.esprit.controllers.DashboardAdminController">

    <!-- ══════════════════════════════ SIDEBAR ══════════════════════════════ -->
    <left>
        <VBox prefWidth="248" styleClass="sidebar-modern">

            <!-- Logo -->
            <VBox alignment="CENTER_LEFT" spacing="3" styleClass="sidebar-logo-zone">
                <Label text="SmartPath"    styleClass="sidebar-logo-title"/>
                <Label text="Administration" styleClass="sidebar-logo-subtitle"/>
            </VBox>

            <VBox spacing="2" style="-fx-padding: 16 10 0 10;">
                <Label styleClass="sidebar-section-label" text="MENU"/>

                <!-- Dashboard -->
                <Button fx:id="btnDashboard" maxWidth="Infinity"
                        onAction="#showDashboard"
                        styleClass="nav-btn-active" text="🏠  Dashboard"/>

                <!-- ── Utilisateurs (avec sous-menu) ── -->
                <Button fx:id="btnUsers" maxWidth="Infinity"
                        onAction="#toggleUsersMenu"
                        styleClass="nav-btn" text="👥  Utilisateurs  ▾"/>
                <VBox fx:id="usersSubMenu" managed="false" visible="false" spacing="2"
                      style="-fx-padding: 0 0 0 18;">
                    <Button fx:id="btnGestionProfs" maxWidth="Infinity"
                            onAction="#showProfsFromMenu"
                            text="👨‍🏫  Gestion profs"
                            style="-fx-font-size:12;-fx-background-color:#f1f5fe;-fx-text-fill:#4f46e5;
                                   -fx-background-radius:7;-fx-padding:7 14;-fx-cursor:hand;
                                   -fx-border-color:#c7d2fe;-fx-border-radius:7;-fx-border-width:1;"/>
                    <Button fx:id="btnGestionEtudiants" maxWidth="Infinity"
                            onAction="#showEtudiantsFromMenu"
                            text="👨‍🎓  Gestion étudiants"
                            style="-fx-font-size:12;-fx-background-color:#f1f5fe;-fx-text-fill:#4f46e5;
                                   -fx-background-radius:7;-fx-padding:7 14;-fx-cursor:hand;
                                   -fx-border-color:#c7d2fe;-fx-border-radius:7;-fx-border-width:1;"/>
                </VBox>

                <Button fx:id="btnFilieres" maxWidth="Infinity"
                        onAction="#showFilieres"
                        styleClass="nav-btn" text="📚  Filières"/>
                <Button fx:id="btnOffres" maxWidth="Infinity"
                        onAction="#showOffres"
                        styleClass="nav-btn" text="💼  Offres de stage"/>

                <!-- ── Statistiques (sous-menu User / Quiz) ── -->
                <Label text="STATISTIQUES" styleClass="sidebar-section-label"
                       style="-fx-padding:12 0 4 8;"/>

                <!--
                    Bouton parent : un seul bouton "Statistiques"
                    Le ▾ indique qu'il y a un sous-menu
                -->
                <Button fx:id="btnStatistiques" maxWidth="Infinity"
                        onAction="#toggleStatsMenu"
                        styleClass="nav-btn" text="📊  Statistiques  ▾"/>

                <!--
                    Sous-menu caché par défaut.
                    Devient visible quand l'utilisateur clique sur "Statistiques".
                -->
                <VBox fx:id="statsSubMenu" managed="false" visible="false" spacing="2"
                      style="-fx-padding: 0 0 0 18;">

                    <!-- Bouton 1 : Statistiques Utilisateurs -->
                    <Button fx:id="btnStatistiquesUsers" maxWidth="Infinity"
                            onAction="#showStatistiquesUsers"
                            text="📈  Utilisateurs"
                            style="-fx-font-size:12;-fx-background-color:#ede9fe;-fx-text-fill:#6d28d9;
                                   -fx-background-radius:7;-fx-padding:7 14;-fx-cursor:hand;
                                   -fx-border-color:#ddd6fe;-fx-border-radius:7;-fx-border-width:1;"/>

                    <!-- Bouton 2 : Statistiques Quiz -->
                    <Button fx:id="btnStatistiquesQuiz" maxWidth="Infinity"
                            onAction="#showStatistiquesQuiz"
                            text="🧩  Quiz"
                            style="-fx-font-size:12;-fx-background-color:#d1fae5;-fx-text-fill:#065f46;
                                   -fx-background-radius:7;-fx-padding:7 14;-fx-cursor:hand;
                                   -fx-border-color:#a7f3d0;-fx-border-radius:7;-fx-border-width:1;"/>
                </VBox>

                <!-- ── Quiz ── -->
                <Label text="QUIZ" styleClass="sidebar-section-label"
                       style="-fx-padding:12 0 4 8;"/>
                <Button fx:id="btnQuizAdmin" maxWidth="Infinity"
                        onAction="#showQuizAdmin"
                        styleClass="nav-btn" text="🧠  Questions du Quiz"/>
                <Button fx:id="btnQuizHistorique" maxWidth="Infinity"
                        onAction="#showQuizHistorique"
                        styleClass="nav-btn" text="📋  Historique Quiz"/>

                <Button fx:id="btnProfil" maxWidth="Infinity"
                        onAction="#showProfil"
                        styleClass="nav-btn" text="👤  Mon profil"/>
            </VBox>

            <Pane VBox.vgrow="ALWAYS"/>

            <VBox style="-fx-padding: 0 10 12 10;">
                <Button fx:id="btnVueEtudiant" maxWidth="Infinity"
                        onAction="#switchToVueEtudiant"
                        styleClass="chip-btn" text="👁  Vue Étudiant"/>
            </VBox>

            <VBox styleClass="sidebar-footer">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="avatar-admin" text="A"/>
                    <VBox spacing="1">
                        <Label fx:id="adminNameLabel" styleClass="user-name" text="Admin"/>
                        <Label styleClass="user-role"  text="Administrateur"/>
                    </VBox>
                </HBox>
                <Button maxWidth="Infinity" onAction="#handleLogout"
                        styleClass="btn-logout" text="Se déconnecter"/>
            </VBox>
        </VBox>
    </left>

    <!-- ══════════════════════════════ CONTENT ══════════════════════════════ -->
    <center>
        <VBox styleClass="app-content">
            <HBox alignment="CENTER_LEFT" styleClass="topbar-modern">
                <Label fx:id="pageTitle" styleClass="topbar-title" text="Dashboard"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="dateLabel" styleClass="topbar-date" text=""/>
            </HBox>

            <StackPane fx:id="contentArea" style="-fx-padding: 24 28;" VBox.vgrow="ALWAYS">

                <!-- Vue Dashboard par défaut -->
                <VBox fx:id="dashboardView" spacing="22">
                    <VBox spacing="3">
                        <Label style="-fx-font-size:17;-fx-font-weight:bold;-fx-text-fill:#1a2340;"
                               text="Vue d'ensemble"/>
                        <Label style="-fx-font-size:12;-fx-text-fill:#8898b8;"
                               text="Statistiques générales de la plateforme"/>
                    </VBox>

                    <!-- Cartes chiffres clés -->
                    <HBox spacing="16">
                        <VBox spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-font-size:20;" text="👥"/>
                                <Label styleClass="stat-label" text="Utilisateurs"/>
                            </HBox>
                            <Label fx:id="totalUsers" styleClass="stat-number" text="—"/>
                            <Label styleClass="muted-label" text="Total inscrits"/>
                        </VBox>
                        <VBox spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-font-size:20;" text="🎓"/>
                                <Label styleClass="stat-label" text="Étudiants"/>
                            </HBox>
                            <Label fx:id="totalEtudiants" styleClass="stat-number-green" text="—"/>
                            <Label styleClass="muted-label" text="Apprenants actifs"/>
                        </VBox>
                        <VBox spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-font-size:20;" text="👨‍🏫"/>
                                <Label styleClass="stat-label" text="Professeurs"/>
                            </HBox>
                            <Label fx:id="totalProfs" styleClass="stat-number-purple" text="—"/>
                            <Label styleClass="muted-label" text="Enseignants"/>
                        </VBox>
                        <VBox spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-font-size:20;" text="💼"/>
                                <Label styleClass="stat-label" text="Offres"/>
                            </HBox>
                            <Label fx:id="totalOffres" styleClass="stat-number-amber" text="—"/>
                            <Label styleClass="muted-label" text="Offres de stage"/>
                        </VBox>
                    </HBox>

                    <!-- Actions rapides -->
                    <VBox spacing="14" styleClass="section-card">
                        <VBox spacing="3">
                            <Label styleClass="card-title" text="Actions rapides"/>
                            <Label styleClass="card-subtitle"
                                   text="Gérez rapidement les ressources de la plateforme"/>
                        </VBox>
                        <HBox spacing="12">
                            <Button onAction="#showEtudiants" styleClass="chip-btn"
                                    text="👨‍🎓  Gérer les étudiants"/>
                            <Button onAction="#showProfs" styleClass="chip-btn-success"
                                    text="👨‍🏫  Gérer les professeurs"/>
                            <Button onAction="#showFilieres" styleClass="chip-btn-warn"
                                    text="📚  Gérer les filières"/>
                            <Button onAction="#showStatistiquesUsers" styleClass="chip-btn"
                                    text="📈  Stats Utilisateurs"
                                    style="-fx-background-color:#ede9fe;-fx-text-fill:#6d28d9;"/>
                            <Button onAction="#showStatistiquesQuiz" styleClass="chip-btn"
                                    text="🧩  Stats Quiz"
                                    style="-fx-background-color:#d1fae5;-fx-text-fill:#065f46;"/>
                        </HBox>
                    </VBox>

                    <!-- TableView caché pour compatibilité -->
                    <VBox managed="false" visible="false">
                        <TableView fx:id="usersTable">
                            <columns>
                                <TableColumn fx:id="colNom"/>
                                <TableColumn fx:id="colPrenom"/>
                                <TableColumn fx:id="colEmail"/>
                                <TableColumn fx:id="colType"/>
                                <TableColumn fx:id="colStatus"/>
                                <TableColumn fx:id="colActions"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
