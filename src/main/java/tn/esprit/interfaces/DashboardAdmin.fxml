<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.DashboardAdminController"
            prefWidth="1200" prefHeight="700"
            stylesheets="@smartpath.css"
            styleClass="app-bg">

    <!-- ═══════ SIDEBAR ═══════ -->
    <left>
        <VBox prefWidth="248" styleClass="sidebar-modern">

            <!-- Logo zone -->
            <VBox alignment="CENTER_LEFT" spacing="3" styleClass="sidebar-logo-zone">
                <Label text="SmartPath" styleClass="sidebar-logo-title"/>
                <Label text="Administration" styleClass="sidebar-logo-subtitle"/>
            </VBox>

            <!-- Navigation principale -->
            <VBox spacing="2" style="-fx-padding: 16 10 0 10;">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button fx:id="btnDashboard" text="🏠  Dashboard"        onAction="#showDashboard"   maxWidth="Infinity" styleClass="nav-btn-active"/>
                <Button fx:id="btnUsers"     text="👥  Utilisateurs"      onAction="#showUsers"       maxWidth="Infinity" styleClass="nav-btn"/>
                <Button fx:id="btnFilieres"  text="📚  Filières"          onAction="#showFilieres"    maxWidth="Infinity" styleClass="nav-btn"/>
                <Button fx:id="btnOffres"    text="💼  Offres de stage"   onAction="#showOffres"      maxWidth="Infinity" styleClass="nav-btn"/>
                <Button fx:id="btnQuizAdmin" text="🧠  Quiz personnalité" onAction="#showQuizAdmin"   maxWidth="Infinity" styleClass="nav-btn"/>
                <Button fx:id="btnProfil"    text="👤  Mon profil"        onAction="#showProfil"      maxWidth="Infinity" styleClass="nav-btn"/>
            </VBox>

            <Pane VBox.vgrow="ALWAYS"/>

            <!-- Bouton vue étudiant -->
            <VBox style="-fx-padding: 0 10 12 10;">
                <Button fx:id="btnVueEtudiant" text="👁  Vue Étudiant"
                        onAction="#switchToVueEtudiant" maxWidth="Infinity" styleClass="chip-btn"/>
            </VBox>

            <!-- Footer utilisateur -->
            <VBox styleClass="sidebar-footer">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="A" styleClass="avatar-admin"/>
                    <VBox spacing="1">
                        <Label fx:id="adminNameLabel" text="Admin" styleClass="user-name"/>
                        <Label text="Administrateur" styleClass="user-role"/>
                    </VBox>
                </HBox>
                <Button text="Se déconnecter" onAction="#handleLogout"
                        maxWidth="Infinity" styleClass="btn-logout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════ CENTRE ═══════ -->
    <center>
        <VBox styleClass="app-content">

            <!-- Topbar -->
            <HBox alignment="CENTER_LEFT" styleClass="topbar-modern">
                <Label fx:id="pageTitle" text="Dashboard" styleClass="topbar-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="dateLabel" text="" styleClass="topbar-date"/>
            </HBox>

            <!-- Contenu dynamique -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-padding: 24 28;">
                <VBox fx:id="dashboardView" spacing="22">

                    <!-- Titre section -->
                    <VBox spacing="3">
                        <Label text="Vue d'ensemble"
                               style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                        <Label text="Statistiques générales de la plateforme"
                               style="-fx-font-size: 12; -fx-text-fill: #8898b8;"/>
                    </VBox>

                    <!-- Cartes stats -->
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="stat-card">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="👥" style="-fx-font-size: 20;"/>
                                <Label text="Utilisateurs" styleClass="stat-label"/>
                            </HBox>
                            <Label fx:id="totalUsers" text="—" styleClass="stat-number"/>
                            <Label text="Total inscrits" styleClass="muted-label"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="stat-card">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="🎓" style="-fx-font-size: 20;"/>
                                <Label text="Étudiants" styleClass="stat-label"/>
                            </HBox>
                            <Label fx:id="totalEtudiants" text="—" styleClass="stat-number-green"/>
                            <Label text="Apprenants actifs" styleClass="muted-label"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="stat-card">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="👨‍🏫" style="-fx-font-size: 20;"/>
                                <Label text="Professeurs" styleClass="stat-label"/>
                            </HBox>
                            <Label fx:id="totalProfs" text="—" styleClass="stat-number-purple"/>
                            <Label text="Enseignants" styleClass="muted-label"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="stat-card">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="💼" style="-fx-font-size: 20;"/>
                                <Label text="Offres" styleClass="stat-label"/>
                            </HBox>
                            <Label fx:id="totalOffres" text="—" styleClass="stat-number-amber"/>
                            <Label text="Offres de stage" styleClass="muted-label"/>
                        </VBox>
                    </HBox>

                    <!-- Actions rapides -->
                    <VBox spacing="14" styleClass="section-card">
                        <VBox spacing="3">
                            <Label text="Actions rapides" styleClass="card-title"/>
                            <Label text="Gérez rapidement les ressources de la plateforme"
                                   styleClass="card-subtitle"/>
                        </VBox>
                        <HBox spacing="12">
                            <Button text="➕  Ajouter un utilisateur" onAction="#showUsers"     styleClass="chip-btn"/>
                            <Button text="📚  Gérer les filières"     onAction="#showFilieres"  styleClass="chip-btn-success"/>
                            <Button text="💼  Voir les offres"        onAction="#showOffres"    styleClass="chip-btn-warn"/>
                        </HBox>
                    </VBox>

                    <!-- Champs cachés contrôleur -->
                    <VBox visible="false" managed="false">
                        <TableView fx:id="usersTable">
                            <columns>
                                <TableColumn fx:id="colNom"/>
                                <TableColumn fx:id="colPrenom"/>
                                <TableColumn fx:id="colEmail"/>
                                <TableColumn fx:id="colType"/>
                                <TableColumn fx:id="colStatus"/>
                                <TableColumn fx:id="colActions"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </StackPane>
        </VBox>
    </center>

</BorderPane>
