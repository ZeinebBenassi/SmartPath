<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.DashboardEtudiantController"
            prefWidth="1200" prefHeight="700"
            style="-fx-background-color: #f4f6fb;">

    <left>
        <VBox prefWidth="240" style="-fx-background-color: white; -fx-border-color: #e2e8f4; -fx-border-width: 0 1 0 0;">
            <VBox alignment="CENTER_LEFT" style="-fx-padding: 18 16 14 16; -fx-border-color: #e2e8f4; -fx-border-width: 0 0 1 0;" spacing="2">
                <Label text="SmartPath" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <Label text="Espace Étudiant" style="-fx-font-size: 11; -fx-text-fill: #8898b8;"/>
            </VBox>

            <VBox spacing="4" style="-fx-padding: 14 10 0 10;">
                <Button fx:id="btnAccueil" text="  Accueil" onAction="#showAccueil" maxWidth="Infinity" style="-fx-background-color: #eff6ff; -fx-text-fill: #2563eb; -fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnAboutContact" text="  About / Contact" onAction="#showAboutContact" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnCours" text="  Mes cours" onAction="#showCours" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnQuiz" text="  Quiz orientation" onAction="#showQuiz" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnSmartPath" text="  SmartPath" onAction="#showSmartPath" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnStages" text="  Stages &amp; Offres" onAction="#showStages" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnReleve" text="  Relevé de notes" onAction="#showReleve" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnProfil" text="  Mon profil" onAction="#showProfil" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #5a6a8a; -fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnRetourDashboard" text="  ← Retour Dashboard" onAction="#returnToSourceDashboard" visible="false" managed="false" maxWidth="Infinity" style="-fx-background-color: #eff6ff; -fx-text-fill: #2563eb; -fx-font-size: 12; -fx-padding: 9 16; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-border-color: #bfdbfe; -fx-border-radius: 8;"/>
            </VBox>

            <Pane VBox.vgrow="ALWAYS"/>
            <VBox style="-fx-padding: 12; -fx-border-color: #e2e8f4; -fx-border-width: 1 0 0 0;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="E" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-min-width: 36; -fx-min-height: 36; -fx-background-radius: 18; -fx-alignment: CENTER;"/>
                    <VBox spacing="2">
                        <Label fx:id="etudiantNameLabel" text="Étudiant" style="-fx-text-fill: #1a2340; -fx-font-size: 13; -fx-font-weight: bold;"/>
                        <Label fx:id="etudiantNiveauLabel" text="" style="-fx-text-fill: #8898b8; -fx-font-size: 11;"/>
                    </VBox>
                </HBox>
                <Button text="Déconnexion" onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-size: 12; -fx-padding: 8 0 4 0;"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #f4f6fb;">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 28; -fx-border-color: #e2e8f4; -fx-border-width: 0 0 1 0; -fx-background-color: white;">
                <Label fx:id="welcomeLabel" text="Bonjour !" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                <Pane HBox.hgrow="ALWAYS"/>
            </HBox>

            <ScrollPane fx:id="accueilScroll" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;" hbarPolicy="NEVER">
                <content>
                    <VBox spacing="18" style="-fx-padding: 24 28 28 28; -fx-background-color: #f4f6fb;">
                        <HBox spacing="18" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e2e8f4; -fx-border-radius: 16; -fx-padding: 20;">
                            <VBox spacing="12" HBox.hgrow="ALWAYS" maxWidth="560">
                                <Label text="🚀 Bienvenue sur SmartPath" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                <Label wrapText="true" text="Découvrez une nouvelle façon d'apprendre. Accédez à des cours de qualité, testez vos connaissances et transformez votre avenir avec notre plateforme innovante." style="-fx-font-size: 14; -fx-text-fill: #5a6a8a;"/>
                                <HBox spacing="10">
                                    <Button text="📘 Explorer les Cours" onAction="#showCours" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 10 16; -fx-background-radius: 10;"/>
                                    <Button text="ℹ En Savoir Plus" onAction="#showSmartPath" style="-fx-background-color: #f4f6fb; -fx-text-fill: #1a2340; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 10 16; -fx-background-radius: 10; -fx-border-color: #d9e3f7; -fx-border-radius: 10;"/>
                                </HBox>
                            </VBox>
                            <StackPane prefWidth="260" minHeight="170" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #dbe7fb; -fx-border-radius: 14; -fx-padding: 8;">
                                <ImageView fitWidth="244" fitHeight="154" preserveRatio="false" smooth="true" style="-fx-background-radius: 10;">
                                    <image>
                                        <Image url="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=800&amp;h=600&amp;fit=crop"/>
                                    </image>
                                </ImageView>
                            </StackPane>
                        </HBox>

                        <VBox spacing="8">
                            <Label text="✨ Pourquoi choisir SmartPath ?" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                            <Label text="Découvrez les fonctionnalités qui rendent l'apprentissage efficace et agréable" style="-fx-font-size: 13; -fx-text-fill: #5a6a8a;"/>
                        </VBox>

                        <GridPane hgap="14" vgap="14">
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="6" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f4; -fx-border-radius: 12; -fx-padding: 14;">
                                <Label text="🎯" style="-fx-font-size: 22;"/>
                                <Label text="Apprentissage Personnalisé" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                <Label wrapText="true" text="Des recommandations adaptées à votre style d'apprentissage." style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                            </VBox>
                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="6" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f4; -fx-border-radius: 12; -fx-padding: 14;">
                                <Label text="📚" style="-fx-font-size: 22;"/>
                                <Label text="Bibliothèque de Cours" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                <Label wrapText="true" text="Accédez à de nombreux cours dans divers domaines." style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                            </VBox>
                            <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="6" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f4; -fx-border-radius: 12; -fx-padding: 14;">
                                <Label text="🏆" style="-fx-font-size: 22;"/>
                                <Label text="Quiz Interactifs" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                <Label wrapText="true" text="Testez vos connaissances et progressez rapidement." style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                            </VBox>
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="6" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f4; -fx-border-radius: 12; -fx-padding: 14;">
                                <Label text="📈" style="-fx-font-size: 22;"/>
                                <Label text="Suivi des Progrès" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                <Label wrapText="true" text="Visualisez votre progression avec des indicateurs clairs." style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                            </VBox>
                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="6" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f4; -fx-border-radius: 12; -fx-padding: 14;">
                                <Label text="🌟" style="-fx-font-size: 22;"/>
                                <Label text="Experts Qualifiés" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                <Label wrapText="true" text="Apprenez auprès de professeurs et mentors qualifiés." style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                            </VBox>
                            <VBox GridPane.columnIndex="2" GridPane.rowIndex="1" spacing="6" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f4; -fx-border-radius: 12; -fx-padding: 14;">
                                <Label text="💼" style="-fx-font-size: 22;"/>
                                <Label text="Carrière" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                <Label wrapText="true" text="Développez des compétences utiles pour votre avenir pro." style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;"/>
                            </VBox>
                        </GridPane>

                        <HBox spacing="12" alignment="CENTER" style="-fx-background-color: linear-gradient(to right, #1e3a8a, #2563eb); -fx-background-radius: 14; -fx-padding: 16;">
                            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="50K+" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Label text="Apprenants Actifs" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.85);"/>
                            </VBox>
                            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="500+" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Label text="Cours Disponibles" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.85);"/>
                            </VBox>
                            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="95%" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Label text="Satisfaction" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.85);"/>
                            </VBox>
                            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="24/7" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Label text="Support" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.85);"/>
                            </VBox>
                        </HBox>

                        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 22;">
                            <Label text="🎓 Prêt à commencer ?" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                            <Label text="Rejoignez des milliers d'apprenants qui progressent déjà avec SmartPath." style="-fx-font-size: 13; -fx-text-fill: #5a6a8a;"/>
                            <Button text="Commencer Maintenant" onAction="#showCours" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 10;"/>
                        </VBox>

                        <VBox spacing="6" style="-fx-background-color: #0f172a; -fx-background-radius: 12; -fx-padding: 16;">
                            <Label text="SmartPath" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label wrapText="true" text="Donner aux apprenants les moyens de réussir grâce à une expérience éducative moderne et personnalisée." style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.75);"/>
                            <Label text="© 2026 SmartPath. Tous droits réservés." style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.60);"/>
                        </VBox>

                        <VBox visible="false" managed="false">
                            <Label fx:id="moyenneLabel" text="--"/>
                            <Label fx:id="nbCoursLabel" text="0"/>
                            <Label fx:id="nbOffresLabel" text="0"/>
                            <Label fx:id="quizStatusLabel" text="Non fait"/>
                            <ListView fx:id="coursList"/>
                            <ListView fx:id="offresList"/>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <ScrollPane fx:id="aboutContactScroll" fitToWidth="true" VBox.vgrow="ALWAYS" visible="false" managed="false" style="-fx-background: transparent; -fx-background-color: transparent;" hbarPolicy="NEVER">
                <content>
                    <VBox spacing="14" style="-fx-padding: 24 28 28 28; -fx-background-color: #f4f6fb;">
                        <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f4; -fx-border-radius: 14; -fx-padding: 22;">
                            <Label text="ℹ À Propos de SmartPath" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                            <Label wrapText="true" text="Nous sommes dédiés à transformer l'éducation en la rendant accessible, engageante et adaptée aux besoins de chaque apprenant." style="-fx-font-size: 13; -fx-text-fill: #5a6a8a;"/>

                            <HBox spacing="14">
                                <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fbff; -fx-background-radius: 12; -fx-border-color: #dbe7fb; -fx-border-radius: 12; -fx-padding: 14;">
                                    <Label text="🎯 Notre Mission" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                                    <Label wrapText="true" text="Démocratiser l'accès à une éducation de qualité pour tous, avec des parcours personnalisés, interactifs et accessibles à tout moment." style="-fx-font-size: 12; -fx-text-fill: #4f6488;"/>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fbff; -fx-background-radius: 12; -fx-border-color: #dbe7fb; -fx-border-radius: 12; -fx-padding: 14;">
                                    <Label text="🌟 Notre Vision" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                                    <Label wrapText="true" text="Permettre à chacun d'acquérir les compétences nécessaires pour réaliser ses objectifs et transformer son avenir professionnel." style="-fx-font-size: 12; -fx-text-fill: #4f6488;"/>
                                </VBox>
                            </HBox>

                            <Label text="💎 Nos Valeurs" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                            <GridPane hgap="12" vgap="12">
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5" style="-fx-background-color: #f9fbff; -fx-background-radius: 10; -fx-border-color: #e3ebfa; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="🚀 Innovation" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                    <Label wrapText="true" text="Technologies modernes et méthodes actives." style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;"/>
                                </VBox>
                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5" style="-fx-background-color: #f9fbff; -fx-background-radius: 10; -fx-border-color: #e3ebfa; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="🤝 Accessibilité" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                    <Label wrapText="true" text="Un apprentissage disponible pour tous." style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;"/>
                                </VBox>
                                <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="5" style="-fx-background-color: #f9fbff; -fx-background-radius: 10; -fx-border-color: #e3ebfa; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="⭐ Excellence" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                    <Label wrapText="true" text="Qualité pédagogique et contenus solides." style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;"/>
                                </VBox>
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="5" style="-fx-background-color: #f9fbff; -fx-background-radius: 10; -fx-border-color: #e3ebfa; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="❤️ Passion" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                    <Label wrapText="true" text="Engagement total pour la réussite des apprenants." style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;"/>
                                </VBox>
                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="5" style="-fx-background-color: #f9fbff; -fx-background-radius: 10; -fx-border-color: #e3ebfa; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="🌍 Communauté" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                    <Label wrapText="true" text="Un réseau d'étudiants, professeurs et mentors." style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;"/>
                                </VBox>
                                <VBox GridPane.columnIndex="2" GridPane.rowIndex="1" spacing="5" style="-fx-background-color: #f9fbff; -fx-background-radius: 10; -fx-border-color: #e3ebfa; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="🎓 Impact" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                    <Label wrapText="true" text="Des compétences utiles pour des résultats concrets." style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;"/>
                                </VBox>
                            </GridPane>
                        </VBox>

                        <VBox spacing="12" style="-fx-background-color: linear-gradient(to bottom right, #eff6ff, #f8fbff); -fx-background-radius: 14; -fx-border-color: #dbe7fb; -fx-border-radius: 14; -fx-padding: 20;">
                            <Label text="📞 Contact" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                            <Label text="Une question ? Notre équipe est là pour vous aider." style="-fx-font-size: 13; -fx-text-fill: #4f6488;"/>
                            <HBox spacing="12">
                                <VBox spacing="4" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dbe7fb; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="✉ Email" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                    <Label text="support@smartpath.tn" style="-fx-font-size: 12; -fx-text-fill: #2563eb;"/>
                                </VBox>
                                <VBox spacing="4" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dbe7fb; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="☎ Téléphone" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
                                    <Label text="+216 70 000 000" style="-fx-font-size: 12; -fx-text-fill: #2563eb;"/>
                                </VBox>
                                <VBox spacing="4" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dbe7fb; -fx-border-radius: 10; -fx-padding: 12;">
                                    <Label text="📍 Adresse" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>
