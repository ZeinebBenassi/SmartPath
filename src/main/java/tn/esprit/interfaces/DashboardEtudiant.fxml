<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700" prefWidth="1200" styleClass="app-bg" stylesheets="@smartpath.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="tn.esprit.controllers.DashboardEtudiantController">

    <!-- ═══════ SIDEBAR ═══════ -->
    <left>
        <VBox prefWidth="248" styleClass="sidebar-modern">

            <!-- Logo -->
            <VBox alignment="CENTER_LEFT" spacing="3" styleClass="sidebar-logo-zone">
                <Label text="SmartPath" styleClass="sidebar-logo-title"/>
                <Label text="Espace Étudiant" styleClass="sidebar-logo-subtitle"/>
            </VBox>

            <!-- Navigation -->
            <VBox spacing="2" style="-fx-padding: 16 10 0 10;">
                <Label styleClass="sidebar-section-label" text="MENU" />
                <Button fx:id="btnAccueil" maxWidth="Infinity" onAction="#showAccueil" styleClass="nav-btn-active" text="🏠  Accueil" />
                <Button fx:id="btnCours" maxWidth="Infinity" onAction="#showCours" styleClass="nav-btn" text="📘  Mes cours" />
                <Button fx:id="btnQuiz" maxWidth="Infinity" onAction="#showQuiz" styleClass="nav-btn" text="🧠  Quiz orientation" />
                <Button fx:id="btnStages" maxWidth="Infinity" onAction="#showStages" styleClass="nav-btn" text="💼  Stages &amp; Offres" />
                <Button fx:id="btnAboutContact" maxWidth="Infinity" onAction="#showAboutContact" styleClass="nav-btn" text="ℹ  À propos" />
            </VBox>

            <Pane VBox.vgrow="ALWAYS" />

            <!-- Retour dashboard source -->
            <VBox spacing="4" style="-fx-padding: 0 10 12 10;">
                <Button fx:id="btnRetourDashboard" managed="false" maxWidth="Infinity" onAction="#returnToSourceDashboard" styleClass="chip-btn" text="← Retour Dashboard" visible="false" />
            </VBox>

            <!-- Footer -->
            <VBox styleClass="sidebar-footer">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="avatar-etudiant" text="E" />
                    <VBox spacing="1">
                        <Label fx:id="etudiantNameLabel" styleClass="user-name" text="Étudiant" />
                        <Label fx:id="etudiantNiveauLabel" styleClass="user-role" text="" />
                    </VBox>
                </HBox>
                <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="btn-logout" text="Se déconnecter" />
            </VBox>
        </VBox>
    </left>

    <!-- ═══════ CENTRE ═══════ -->
    <center>
        <VBox styleClass="app-content">

            <!-- Topbar -->
            <HBox alignment="CENTER_LEFT" styleClass="topbar-modern">
                <Label fx:id="welcomeLabel" styleClass="topbar-title" text="Bonjour !" />
                <Pane HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- Zone de contenu -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">

                <!-- ── Vue Accueil ── -->
                <ScrollPane fx:id="homeView" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <VBox spacing="20" style="-fx-padding: 24 28 32 28;">

                            <!-- Hero -->
                            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="section-card">
                                <VBox spacing="14" HBox.hgrow="ALWAYS">
                                    <VBox spacing="6">
                                        <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="🚀 Bienvenue sur SmartPath" />
                                        <Label maxWidth="500" style="-fx-font-size: 13; -fx-text-fill: #5a6a8a;" text="Découvrez une nouvelle façon d'apprendre. Accédez à des cours de qualité, testez vos connaissances et transformez votre avenir." wrapText="true" />
                                    </VBox>
                                    <HBox spacing="10">
                                        <Button onAction="#showCours" styleClass="btn-primary" text="📘 Mes cours" />
                                        <Button onAction="#showQuiz" styleClass="btn-secondary" text="🧠 Quiz" />
                                    </HBox>
                                </VBox>
                                <StackPane prefHeight="150" prefWidth="240" style="-fx-background-color: linear-gradient(to bottom right, #eff6ff, #dbeafe);                                                   -fx-background-radius: 12;">
                                    <ImageView fitHeight="138" fitWidth="220" preserveRatio="false" smooth="true" style="-fx-background-radius: 10;">
                                        <image>
                                            <Image url="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=800&amp;h=600&amp;fit=crop" />
                                        </image>
                                    </ImageView>
                                </StackPane>
                            </HBox>

                            <!-- Stats rapides -->
                            <HBox spacing="16">
                                <VBox alignment="CENTER" spacing="4" style="-fx-background-color: linear-gradient(to bottom right, #1e3a8a, #2563eb); -fx-background-radius: 12; -fx-padding: 18;" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;" text="50K+" />
                                    <Label style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.80);" text="Apprenants" />
                                </VBox>
                                <VBox alignment="CENTER" spacing="4" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 18;" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2563eb;" text="500+" />
                                    <Label style="-fx-font-size: 11; -fx-text-fill: #8898b8;" text="Cours" />
                                </VBox>
                                <VBox alignment="CENTER" spacing="4" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 18;" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="95%" />
                                    <Label style="-fx-font-size: 11; -fx-text-fill: #8898b8;" text="Satisfaction" />
                                </VBox>
                                <VBox alignment="CENTER" spacing="4" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 18;" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3b82f6;" text="24/7" />
                                    <Label style="-fx-font-size: 11; -fx-text-fill: #8898b8;" text="Support" />
                                </VBox>
                            </HBox>

                            <!-- Fonctionnalités -->
                            <VBox spacing="12">
                                <VBox spacing="3">
                                    <Label style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="✨ Pourquoi choisir SmartPath ?" />
                                    <Label style="-fx-font-size: 12; -fx-text-fill: #8898b8;" text="Des outils modernes pour un apprentissage efficace et agréable" />
                                </VBox>

                                <GridPane hgap="14" vgap="14">
                                    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 16;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label style="-fx-font-size: 22;" text="🎯" />
                                        <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="Apprentissage Personnalisé" />
                                        <Label style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;" text="Recommandations adaptées à votre profil." wrapText="true" />
                                    </VBox>
                                    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 16;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label style="-fx-font-size: 22;" text="📚" />
                                        <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="Bibliothèque de Cours" />
                                        <Label style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;" text="Des centaines de cours dans tous les domaines." wrapText="true" />
                                    </VBox>
                                    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 16;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                        <Label style="-fx-font-size: 22;" text="🏆" />
                                        <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="Quiz Interactifs" />
                                        <Label style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;" text="Testez et validez vos connaissances." wrapText="true" />
                                    </VBox>
                                    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 16;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                        <Label style="-fx-font-size: 22;" text="📈" />
                                        <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="Suivi des Progrès" />
                                        <Label style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;" text="Indicateurs clairs de votre évolution." wrapText="true" />
                                    </VBox>
                                    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 16;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                        <Label style="-fx-font-size: 22;" text="🌟" />
                                        <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="Experts Qualifiés" />
                                        <Label style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;" text="Apprenez auprès de professeurs certifiés." wrapText="true" />
                                    </VBox>
                                    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eef8; -fx-border-radius: 12; -fx-padding: 16;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                        <Label style="-fx-font-size: 22;" text="💼" />
                                        <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="Carrière" />
                                        <Label style="-fx-font-size: 11; -fx-text-fill: #5a6a8a;" text="Compétences utiles pour votre avenir pro." wrapText="true" />
                                    </VBox>
                           <columnConstraints>
                              <ColumnConstraints />
                              <ColumnConstraints />
                              <ColumnConstraints />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>
                                </GridPane>
                            </VBox>

                            <!-- CTA bas -->
                            <HBox alignment="CENTER_LEFT" spacing="24" styleClass="section-card">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="🎓 Prêt à commencer ?" />
                                    <Label style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;" text="Rejoignez des milliers d'apprenants qui progressent avec SmartPath." />
                                </VBox>
                                <Button onAction="#showCours" styleClass="btn-primary" text="Commencer →" />
                            </HBox>

                            <!-- Footer -->
                            <VBox spacing="4" style="-fx-background-color: #0f172a; -fx-background-radius: 12; -fx-padding: 16 20;">
                                <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;" text="SmartPath" />
                                <Label style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);" text="Donner aux apprenants les moyens de réussir grâce à une éducation moderne et personnalisée." wrapText="true" />
                                <Label style="-fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.45);" text="© 2026 SmartPath. Tous droits réservés." />
                            </VBox>

                            <!-- Champs cachés contrôleur -->
                            <VBox managed="false" visible="false">
                                <Label fx:id="moyenneLabel" text="--" />
                                <Label fx:id="nbCoursLabel" text="0" />
                                <Label fx:id="nbOffresLabel" text="0" />
                                <Label fx:id="quizStatusLabel" text="Non fait" />
                                <ListView fx:id="coursList" />
                                <ListView fx:id="offresList" />
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- ── Vue À propos / Contact ── -->
                <ScrollPane fx:id="aboutContactView" fitToWidth="true" hbarPolicy="NEVER" managed="false" style="-fx-background: transparent; -fx-background-color: transparent;" visible="false">
                    <content>
                        <VBox spacing="20" style="-fx-padding: 24 28 32 28;">

                            <!-- À propos -->
                            <VBox spacing="16" styleClass="section-card">
                                <VBox spacing="4">
                                    <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="ℹ À Propos de SmartPath" />
                                    <Label style="-fx-font-size: 13; -fx-text-fill: #5a6a8a;" text="Nous transformons l'éducation en la rendant accessible, engageante et adaptée à chaque apprenant." wrapText="true" />
                                </VBox>
                                <HBox spacing="14">
                                    <VBox spacing="8" style="-fx-background-color: #f0f6ff; -fx-background-radius: 10; -fx-border-color: #dbeafe; -fx-border-radius: 10; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;" text="🎯 Notre Mission" />
                                        <Label style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;" text="Démocratiser l'accès à une éducation de qualité, avec des parcours personnalisés et accessibles à tout moment." wrapText="true" />
                                    </VBox>
                                    <VBox spacing="8" style="-fx-background-color: #f0f6ff; -fx-background-radius: 10; -fx-border-color: #dbeafe; -fx-border-radius: 10; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;" text="🌟 Notre Vision" />
                                        <Label style="-fx-font-size: 12; -fx-text-fill: #5a6a8a;" text="Permettre à chacun d'acquérir les compétences nécessaires pour réaliser ses objectifs professionnels." wrapText="true" />
                                    </VBox>
                                </HBox>
                            </VBox>

                            <!-- Contact -->
                            <VBox spacing="14" styleClass="section-card">
                                <VBox spacing="4">
                                    <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a2340;" text="📞 Contactez-nous" />
                                    <Label style="-fx-font-size: 12; -fx-text-fill: #8898b8;" text="Notre équipe est disponible pour répondre à vos questions." />
                                </VBox>
                                <HBox spacing="14">
                                    <VBox spacing="5" style="-fx-background-color: #f7f9fc; -fx-background-radius: 10; -fx-border-color: #e2e8f4; -fx-border-radius: 10; -fx-padding: 14;" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #8898b8;" text="✉  Email" />
                                        <Label style="-fx-font-size: 13; -fx-text-fill: #2563eb; -fx-font-weight: bold;" text="support@smartpath.tn" />
                                    </VBox>
                                    <VBox spacing="5" style="-fx-background-color: #f7f9fc; -fx-background-radius: 10; -fx-border-color: #e2e8f4; -fx-border-radius: 10; -fx-padding: 14;" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #8898b8;" text="☎  Téléphone" />
                                        <Label style="-fx-font-size: 13; -fx-text-fill: #2563eb; -fx-font-weight: bold;" text="+216 70 000 000" />
                                    </VBox>
                                    <VBox spacing="5" style="-fx-background-color: #f7f9fc; -fx-background-radius: 10; -fx-border-color: #e2e8f4; -fx-border-radius: 10; -fx-padding: 14;" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #8898b8;" text="📍  Adresse" />
                                        <Label style="-fx-font-size: 13; -fx-text-fill: #2563eb; -fx-font-weight: bold;" text="Tunis, Tunisie" />
                                    </VBox>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </StackPane>
        </VBox>
    </center>

</BorderPane>
