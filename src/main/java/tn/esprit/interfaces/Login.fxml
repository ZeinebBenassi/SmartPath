<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane prefHeight="620" prefWidth="980"
           style="-fx-background-color: linear-gradient(to bottom right, #eef3ff, #f0f7ff);"
           xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/25"
           fx:controller="tn.esprit.controllers.LoginController">

    <HBox alignment="CENTER" prefHeight="540" prefWidth="880"
          style="-fx-background-color: white;
                 -fx-background-radius: 20;
                 -fx-border-color: #dce8fa;
                 -fx-border-radius: 20;
                 -fx-border-width: 1;">

        <!-- ── Panneau gauche ── -->
        <VBox alignment="CENTER" prefWidth="350" spacing="20"
              style="-fx-background-color: linear-gradient(to bottom right, #1e3a8a, #2563eb);
                     -fx-background-radius: 20 0 0 20;
                     -fx-padding: 48;">

            <ImageView fitWidth="160" preserveRatio="true" smooth="true">
                <image><Image url="@/images/logo.png"/></image>
            </ImageView>

            <VBox spacing="8" alignment="CENTER">
                <Label text="Bon retour !"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label wrapText="true" maxWidth="250" textAlignment="CENTER"
                       text="Connectez-vous pour accéder à votre espace d'apprentissage personnalisé."
                       style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.78); -fx-text-alignment: center;"/>
            </VBox>

            <HBox alignment="CENTER" spacing="6" style="-fx-padding: 10 0 0 0;">
                <Circle radius="4" fill="white" opacity="0.9"/>
                <Circle radius="4" fill="white" opacity="0.4"/>
                <Circle radius="4" fill="white" opacity="0.4"/>
            </HBox>
        </VBox>

        <!-- ── Panneau droit ── -->
        <VBox alignment="CENTER" prefWidth="530" spacing="18"
              style="-fx-padding: 48 56;">

            <HBox maxWidth="400" spacing="0"
                  style="-fx-background-color: #f4f6fb;
                         -fx-background-radius: 10;
                         -fx-border-color: #e2e8f4;
                         -fx-border-radius: 10;
                         -fx-border-width: 1;">
                <Button disable="true" prefHeight="36" prefWidth="200"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 9 0 0 9; -fx-cursor: default;"
                        text="Connexion"/>
                <Button onAction="#goToRegister" prefHeight="36" prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: #8898b8;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 0 9 9 0; -fx-cursor: hand;"
                        text="Inscription"/>
            </HBox>

            <Label text="Se connecter"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a2340;"/>

            <VBox maxWidth="400" spacing="5">
                <Label text="Adresse email"
                       style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"/>
                <TextField fx:id="emailField" prefHeight="44" promptText="exemple@email.com"
                           style="-fx-background-color: #f7f9fc; -fx-text-fill: #1a2340;
                                  -fx-prompt-text-fill: #a0aec0; -fx-border-color: #e2e8f4;
                                  -fx-border-radius: 9; -fx-background-radius: 9;
                                  -fx-padding: 10 14; -fx-font-size: 13;"/>
            </VBox>

            <VBox maxWidth="400" spacing="5">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Mot de passe"
                           style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #5a6a8a;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button onAction="#goToForgotPassword"
                            style="-fx-background-color: transparent; -fx-text-fill: #2563eb;
                                   -fx-font-size: 11; -fx-cursor: hand; -fx-underline: true;"
                            text="Oublié ?"/>
                </HBox>
                <PasswordField fx:id="passwordField" prefHeight="44" promptText="••••••••"
                               style="-fx-background-color: #f7f9fc; -fx-text-fill: #1a2340;
                                      -fx-prompt-text-fill: #a0aec0; -fx-border-color: #e2e8f4;
                                      -fx-border-radius: 9; -fx-background-radius: 9;
                                      -fx-padding: 10 14; -fx-font-size: 13;"/>
            </VBox>

            <Label fx:id="errorLabel" maxWidth="400"
                   style="-fx-font-size: 12; -fx-text-fill: #dc2626;" text="" wrapText="true"/>

            <Button onAction="#handleLogin" prefHeight="46" prefWidth="400"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white;
                           -fx-font-size: 14; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-cursor: hand;"
                    text="Se connecter"/>

            <HBox alignment="CENTER" spacing="6">
                <Label style="-fx-text-fill: #8898b8; -fx-font-size: 12;"
                       text="Pas encore inscrit ?"/>
                <Button onAction="#goToRegister"
                        style="-fx-background-color: transparent; -fx-text-fill: #2563eb;
                               -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"
                        text="Créer un compte"/>
            </HBox>
        </VBox>
    </HBox>
</StackPane>
