<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="700.0" prefWidth="900.0" spacing="30.0" styleClass="root" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.QuizQuestionController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <fx:include source="nav_bar.fxml" />

    <!-- Progress Bar Section -->
    <VBox alignment="CENTER" spacing="10.0">
        <children>
            <ProgressBar fx:id="progressBar" prefHeight="15.0" prefWidth="600.0" progress="0.1" style="-fx-accent: linear-gradient(to right, #3b82f6, #60a5fa, #93c5fd); -fx-background-radius: 10; -fx-border-radius: 10;" />
            <Label fx:id="progressLabel" style="-fx-font-weight: bold; -fx-font-size: 16px;" styleClass="header-subtitle" text="Question 1 sur 10" />
        </children>
    </VBox>

    <!-- Question Card -->
    <VBox fx:id="questionCard" alignment="TOP_CENTER" maxWidth="800" spacing="40.0" styleClass="quiz-container" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>
        <children>
            <Label fx:id="questionNumberLabel" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-letter-spacing: 1px;" text="QUESTION 1 / 10" />
            <Label fx:id="questionTextLabel" styleClass="question-text" text="Quelle est votre préférence de développement ?" textAlignment="CENTER" wrapText="true" />

            <VBox fx:id="answersBox" alignment="CENTER" spacing="15.0">
                <!-- Answer Buttons will be dynamically added here -->
            </VBox>

            <HBox alignment="CENTER" spacing="20.0">
                <children>
                    <Button fx:id="prevBtn" onAction="#handlePrev" prefWidth="150.0" style="-fx-background-color: rgba(96, 165, 250, 0.15); -fx-text-fill: #1e40af; -fx-font-weight: bold; -fx-background-radius: 10;" text="← Précédent" visible="false" />
                    <Button fx:id="nextBtn" disable="true" onAction="#handleNext" prefWidth="150.0" styleClass="btn-primary" text="Suivant →" />
                </children>
            </HBox>
        </children>
    </VBox>
</VBox>
