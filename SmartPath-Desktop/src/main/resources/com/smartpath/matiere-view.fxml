<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartpath.controller.MatiereController"
      spacing="10"
      style="-fx-padding: 20;">

    <Label text="Gestion des Matieres"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="txtTitre" promptText="Titre" prefWidth="200"/>
        <TextField fx:id="txtDesc" promptText="Description" prefWidth="300"/>
        <Button text="Ajouter" onAction="#handleAdd"/>
        <Button text="Modifier" onAction="#handleUpdate"/>
        <Button text="Supprimer" onAction="#handleDelete"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colTitre" text="Titre" prefWidth="250"/>
            <TableColumn fx:id="colDesc" text="Description" prefWidth="450"/>
        </columns>
    </TableView>

</VBox>

